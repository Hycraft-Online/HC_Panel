// HC_Panel Main Menu — Hytown-inspired layout
// Left sidebar: avatar, username, stats
// Right area: 3x3 tile grid for modules
$C = "../Common.ui";

// ─── Color Tokens ───
@BgSurface = #0b1220(0.94);
@BgSurfaceMuted = #0f172a(0.55);
@BgSurfaceStrong = #0f172a(0.85);
@ColorOutline = #ffffff(0.12);
@ColorOutlineStrong = #334155(0.6);
@ColorAccent = #22d3ee;
@ColorText = #e2e8f0;
@ColorTextMuted = #94a3b8;
@ColorTextBright = #ffffff;
@ColorGold = $C.@ColorGoldHighlight;
@ColorDivider = #93844C;

// ─── Typography ───
@TitleStyle = LabelStyle(
  FontSize: 20,
  TextColor: @ColorText,
  RenderBold: true,
  RenderUppercase: true,
  HorizontalAlignment: Center
);

@StatLabelStyle = LabelStyle(
  FontSize: 12,
  TextColor: @ColorTextMuted,
  HorizontalAlignment: Start,
  VerticalAlignment: Center
);

@StatValueStyle = LabelStyle(
  FontSize: 12,
  TextColor: @ColorText,
  RenderBold: true,
  HorizontalAlignment: End,
  VerticalAlignment: Center
);

// ─── Tile Button Style ───
@TileDefaultBg = #0b1220(0.94);
@TileHoverBorder = $C.@ColorGoldHighlight;

// ─── Page Root ───
Group {
  Anchor: (Full: 0);

  SceneBlur {
    Anchor: (Full: 0);
    Background: #000000(0.45);
  }

  Group {
    LayoutMode: Center;
    Anchor: (Full: 0);

    $C.@DecoratedContainer #MainMenuPanel {
      Anchor: (Width: 1020, Height: 580);

      #Title {
        Group {
          LayoutMode: Center;
          Anchor: (Full: 0);

          Label {
            Text: "HYCRAFT";
            Anchor: (Left: 0, Right: 0, Height: 26);
            Style: @TitleStyle;
          }
        }
      }

      #Content {
        Group #MainRow {
          FlexWeight: 1;
          LayoutMode: Left;

          // ─── Left Player Sidebar ───
          Group #PlayerSidebar {
            Anchor: (Width: 190, Top: 0, Bottom: 0);
            LayoutMode: Top;
            Padding: (Horizontal: 16, Top: 20, Bottom: 16);

            // Avatar placeholder — initials shown via label
            Group #AvatarFrame {
              Anchor: (Width: 80, Height: 80);
              Background: @BgSurfaceStrong;
              OutlineColor: @ColorOutlineStrong;
              OutlineSize: 2;
              LayoutMode: Center;

              Label #AvatarInitial {
                Text: "?";
                Anchor: (Width: 80, Height: 80);
                Style: (FontSize: 32, TextColor: @ColorAccent, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center);
              }
            }

            Group { Anchor: (Height: 12); }

            // Player name
            Label #UsernameLabel {
              Text: "Player";
              Anchor: (Left: 0, Right: 0, Height: 22);
              Style: (FontSize: 16, TextColor: @ColorTextBright, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center);
            }

            // Subtitle (class / faction)
            Label #SubtitleLabel {
              Text: "";
              Anchor: (Left: 0, Right: 0, Height: 18);
              Style: (FontSize: 12, TextColor: @ColorTextMuted, HorizontalAlignment: Center, VerticalAlignment: Center);
            }

            Group { Anchor: (Height: 10); }

            // Separator
            Group {
              Anchor: (Left: 0, Right: 0, Height: 1);
              Background: @ColorOutline;
            }

            Group { Anchor: (Height: 12); }

            // Level
            Group {
              LayoutMode: Left;
              Anchor: (Left: 0, Right: 0, Height: 18);

              Label {
                Text: "Level";
                Style: @StatLabelStyle;
                FlexWeight: 1;
              }
              Label #LevelValue {
                Text: "...";
                Style: (FontSize: 12, TextColor: @ColorAccent, RenderBold: true, HorizontalAlignment: End, VerticalAlignment: Center);
                Anchor: (Width: 60, Height: 18);
              }
            }

            Group { Anchor: (Height: 6); }

            // Class
            Group {
              LayoutMode: Left;
              Anchor: (Left: 0, Right: 0, Height: 18);

              Label {
                Text: "Class";
                Style: @StatLabelStyle;
                FlexWeight: 1;
              }
              Label #ClassValue {
                Text: "...";
                Style: @StatValueStyle;
                Anchor: (Width: 80, Height: 18);
              }
            }

            Group { Anchor: (Height: 6); }

            // Faction
            Group {
              LayoutMode: Left;
              Anchor: (Left: 0, Right: 0, Height: 18);

              Label {
                Text: "Faction";
                Style: @StatLabelStyle;
                FlexWeight: 1;
              }
              Label #FactionValue {
                Text: "...";
                Style: @StatValueStyle;
                Anchor: (Width: 80, Height: 18);
              }
            }

            Group { Anchor: (Height: 6); }

            // Guild
            Group {
              LayoutMode: Left;
              Anchor: (Left: 0, Right: 0, Height: 18);

              Label {
                Text: "Guild";
                Style: @StatLabelStyle;
                FlexWeight: 1;
              }
              Label #GuildValue {
                Text: "...";
                Style: @StatValueStyle;
                Anchor: (Width: 80, Height: 18);
              }
            }

            // Spacer
            Group { FlexWeight: 1; }

            // Bottom separator
            Group {
              Anchor: (Left: 0, Right: 0, Height: 1);
              Background: @ColorOutline;
            }

            Group { Anchor: (Height: 10); }

            // Online count
            Group {
              LayoutMode: Left;
              Anchor: (Left: 0, Right: 0, Height: 18);

              Label {
                Text: "Online";
                Style: @StatLabelStyle;
                FlexWeight: 1;
              }
              Label #OnlineValue {
                Text: "0";
                Style: @StatValueStyle;
                Anchor: (Width: 60, Height: 18);
              }
            }

            Group { Anchor: (Height: 10); }

            // Discord
            Group {
              Anchor: (Left: 0, Right: 0, Height: 1);
              Background: @ColorOutline;
            }

            Group { Anchor: (Height: 10); }

            Label #DiscordLabel {
              Text: "discord.gg/hycraft";
              Anchor: (Left: 0, Right: 0, Height: 20);
              Style: (FontSize: 12, TextColor: #5865F2, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center);
            }
          }

          // Vertical divider
          Group {
            Anchor: (Width: 1, Top: 0, Bottom: 0);
            Background: #ffffff(0.15);
          }

          // ─── Right Tile Grid ───
          Group #TileArea {
            FlexWeight: 1;
            LayoutMode: Top;
            Padding: (Horizontal: 20, Top: 16, Bottom: 16);

            Group #TileGrid {
              Anchor: (Left: 0, Right: 0);
              LayoutMode: Top;

              // Row 0
              Group #TileRow0 {
                LayoutMode: Left;
                Anchor: (Left: 0, Right: 0, Height: 140);

                Group #Slot0 {
                  FlexWeight: 1;
                  Button #TileBtn0 {
                    Anchor: (Full: 0);
                    LayoutMode: Full;
                    Style: (
                      Default:  (Background: @BgSurface),
                      Hovered:  (Background: @TileHoverBorder),
                      Pressed:  (Background: #b8862e),
                      Disabled: (Background: #1a2030)
                    );
                    Group #TileInner0 {
                      Anchor: (Full: 2);
                      Background: @BgSurface;
                      LayoutMode: Top;
                      Padding: (Horizontal: 14, Vertical: 10);
                      Group { Anchor: (Height: 6); }
                      ItemIcon #TileIcon0 { Anchor: (Width: 28, Height: 28); }
                      Group { Anchor: (Height: 8); }
                      Label #TileTitle0 {
                        Text: "Module";
                        Anchor: (Left: 0, Right: 0, Height: 20);
                        Style: (FontSize: 16, TextColor: $C.@ColorDefault, RenderBold: true, HorizontalAlignment: Start, VerticalAlignment: Center);
                      }
                      Group { Anchor: (Height: 4); }
                      Label #TileDesc0 {
                        Text: "Description";
                        Anchor: (Left: 0, Right: 0, Height: 30);
                        Style: (FontSize: 12, TextColor: $C.@ColorDefaultLabel, HorizontalAlignment: Start, VerticalAlignment: Start, Wrap: true);
                      }
                    }
                  }
                }
                Group { Anchor: (Width: 16); }
                Group #Slot1 {
                  FlexWeight: 1;
                  Button #TileBtn1 {
                    Anchor: (Full: 0);
                    LayoutMode: Full;
                    Style: (
                      Default:  (Background: @BgSurface),
                      Hovered:  (Background: @TileHoverBorder),
                      Pressed:  (Background: #b8862e),
                      Disabled: (Background: #1a2030)
                    );
                    Group #TileInner1 {
                      Anchor: (Full: 2);
                      Background: @BgSurface;
                      LayoutMode: Top;
                      Padding: (Horizontal: 14, Vertical: 10);
                      Group { Anchor: (Height: 6); }
                      ItemIcon #TileIcon1 { Anchor: (Width: 28, Height: 28); }
                      Group { Anchor: (Height: 8); }
                      Label #TileTitle1 {
                        Text: "Module";
                        Anchor: (Left: 0, Right: 0, Height: 20);
                        Style: (FontSize: 16, TextColor: $C.@ColorDefault, RenderBold: true, HorizontalAlignment: Start, VerticalAlignment: Center);
                      }
                      Group { Anchor: (Height: 4); }
                      Label #TileDesc1 {
                        Text: "Description";
                        Anchor: (Left: 0, Right: 0, Height: 30);
                        Style: (FontSize: 12, TextColor: $C.@ColorDefaultLabel, HorizontalAlignment: Start, VerticalAlignment: Start, Wrap: true);
                      }
                    }
                  }
                }
                Group { Anchor: (Width: 16); }
                Group #Slot2 {
                  FlexWeight: 1;
                  Button #TileBtn2 {
                    Anchor: (Full: 0);
                    LayoutMode: Full;
                    Style: (
                      Default:  (Background: @BgSurface),
                      Hovered:  (Background: @TileHoverBorder),
                      Pressed:  (Background: #b8862e),
                      Disabled: (Background: #1a2030)
                    );
                    Group #TileInner2 {
                      Anchor: (Full: 2);
                      Background: @BgSurface;
                      LayoutMode: Top;
                      Padding: (Horizontal: 14, Vertical: 10);
                      Group { Anchor: (Height: 6); }
                      ItemIcon #TileIcon2 { Anchor: (Width: 28, Height: 28); }
                      Group { Anchor: (Height: 8); }
                      Label #TileTitle2 {
                        Text: "Module";
                        Anchor: (Left: 0, Right: 0, Height: 20);
                        Style: (FontSize: 16, TextColor: $C.@ColorDefault, RenderBold: true, HorizontalAlignment: Start, VerticalAlignment: Center);
                      }
                      Group { Anchor: (Height: 4); }
                      Label #TileDesc2 {
                        Text: "Description";
                        Anchor: (Left: 0, Right: 0, Height: 30);
                        Style: (FontSize: 12, TextColor: $C.@ColorDefaultLabel, HorizontalAlignment: Start, VerticalAlignment: Start, Wrap: true);
                      }
                    }
                  }
                }
              }

              Group { Anchor: (Height: 16); }

              // Row 1
              Group #TileRow1 {
                LayoutMode: Left;
                Anchor: (Left: 0, Right: 0, Height: 140);

                Group #Slot3 {
                  FlexWeight: 1;
                  Button #TileBtn3 {
                    Anchor: (Full: 0);
                    LayoutMode: Full;
                    Style: (
                      Default:  (Background: @BgSurface),
                      Hovered:  (Background: @TileHoverBorder),
                      Pressed:  (Background: #b8862e),
                      Disabled: (Background: #1a2030)
                    );
                    Group #TileInner3 {
                      Anchor: (Full: 2);
                      Background: @BgSurface;
                      LayoutMode: Top;
                      Padding: (Horizontal: 14, Vertical: 10);
                      Group { Anchor: (Height: 6); }
                      ItemIcon #TileIcon3 { Anchor: (Width: 28, Height: 28); }
                      Group { Anchor: (Height: 8); }
                      Label #TileTitle3 {
                        Text: "Module";
                        Anchor: (Left: 0, Right: 0, Height: 20);
                        Style: (FontSize: 16, TextColor: $C.@ColorDefault, RenderBold: true, HorizontalAlignment: Start, VerticalAlignment: Center);
                      }
                      Group { Anchor: (Height: 4); }
                      Label #TileDesc3 {
                        Text: "Description";
                        Anchor: (Left: 0, Right: 0, Height: 30);
                        Style: (FontSize: 12, TextColor: $C.@ColorDefaultLabel, HorizontalAlignment: Start, VerticalAlignment: Start, Wrap: true);
                      }
                    }
                  }
                }
                Group { Anchor: (Width: 16); }
                Group #Slot4 {
                  FlexWeight: 1;
                  Button #TileBtn4 {
                    Anchor: (Full: 0);
                    LayoutMode: Full;
                    Style: (
                      Default:  (Background: @BgSurface),
                      Hovered:  (Background: @TileHoverBorder),
                      Pressed:  (Background: #b8862e),
                      Disabled: (Background: #1a2030)
                    );
                    Group #TileInner4 {
                      Anchor: (Full: 2);
                      Background: @BgSurface;
                      LayoutMode: Top;
                      Padding: (Horizontal: 14, Vertical: 10);
                      Group { Anchor: (Height: 6); }
                      ItemIcon #TileIcon4 { Anchor: (Width: 28, Height: 28); }
                      Group { Anchor: (Height: 8); }
                      Label #TileTitle4 {
                        Text: "Module";
                        Anchor: (Left: 0, Right: 0, Height: 20);
                        Style: (FontSize: 16, TextColor: $C.@ColorDefault, RenderBold: true, HorizontalAlignment: Start, VerticalAlignment: Center);
                      }
                      Group { Anchor: (Height: 4); }
                      Label #TileDesc4 {
                        Text: "Description";
                        Anchor: (Left: 0, Right: 0, Height: 30);
                        Style: (FontSize: 12, TextColor: $C.@ColorDefaultLabel, HorizontalAlignment: Start, VerticalAlignment: Start, Wrap: true);
                      }
                    }
                  }
                }
                Group { Anchor: (Width: 16); }
                Group #Slot5 {
                  FlexWeight: 1;
                  Button #TileBtn5 {
                    Anchor: (Full: 0);
                    LayoutMode: Full;
                    Style: (
                      Default:  (Background: @BgSurface),
                      Hovered:  (Background: @TileHoverBorder),
                      Pressed:  (Background: #b8862e),
                      Disabled: (Background: #1a2030)
                    );
                    Group #TileInner5 {
                      Anchor: (Full: 2);
                      Background: @BgSurface;
                      LayoutMode: Top;
                      Padding: (Horizontal: 14, Vertical: 10);
                      Group { Anchor: (Height: 6); }
                      ItemIcon #TileIcon5 { Anchor: (Width: 28, Height: 28); }
                      Group { Anchor: (Height: 8); }
                      Label #TileTitle5 {
                        Text: "Module";
                        Anchor: (Left: 0, Right: 0, Height: 20);
                        Style: (FontSize: 16, TextColor: $C.@ColorDefault, RenderBold: true, HorizontalAlignment: Start, VerticalAlignment: Center);
                      }
                      Group { Anchor: (Height: 4); }
                      Label #TileDesc5 {
                        Text: "Description";
                        Anchor: (Left: 0, Right: 0, Height: 30);
                        Style: (FontSize: 12, TextColor: $C.@ColorDefaultLabel, HorizontalAlignment: Start, VerticalAlignment: Start, Wrap: true);
                      }
                    }
                  }
                }
              }

              Group { Anchor: (Height: 16); }

              // Row 2
              Group #TileRow2 {
                LayoutMode: Left;
                Anchor: (Left: 0, Right: 0, Height: 140);

                Group #Slot6 {
                  FlexWeight: 1;
                  Button #TileBtn6 {
                    Anchor: (Full: 0);
                    LayoutMode: Full;
                    Style: (
                      Default:  (Background: @BgSurface),
                      Hovered:  (Background: @TileHoverBorder),
                      Pressed:  (Background: #b8862e),
                      Disabled: (Background: #1a2030)
                    );
                    Group #TileInner6 {
                      Anchor: (Full: 2);
                      Background: @BgSurface;
                      LayoutMode: Top;
                      Padding: (Horizontal: 14, Vertical: 10);
                      Group { Anchor: (Height: 6); }
                      ItemIcon #TileIcon6 { Anchor: (Width: 28, Height: 28); }
                      Group { Anchor: (Height: 8); }
                      Label #TileTitle6 {
                        Text: "Module";
                        Anchor: (Left: 0, Right: 0, Height: 20);
                        Style: (FontSize: 16, TextColor: $C.@ColorDefault, RenderBold: true, HorizontalAlignment: Start, VerticalAlignment: Center);
                      }
                      Group { Anchor: (Height: 4); }
                      Label #TileDesc6 {
                        Text: "Description";
                        Anchor: (Left: 0, Right: 0, Height: 30);
                        Style: (FontSize: 12, TextColor: $C.@ColorDefaultLabel, HorizontalAlignment: Start, VerticalAlignment: Start, Wrap: true);
                      }
                    }
                  }
                }
                Group { Anchor: (Width: 16); }
                Group #Slot7 {
                  FlexWeight: 1;
                  Button #TileBtn7 {
                    Anchor: (Full: 0);
                    LayoutMode: Full;
                    Style: (
                      Default:  (Background: @BgSurface),
                      Hovered:  (Background: @TileHoverBorder),
                      Pressed:  (Background: #b8862e),
                      Disabled: (Background: #1a2030)
                    );
                    Group #TileInner7 {
                      Anchor: (Full: 2);
                      Background: @BgSurface;
                      LayoutMode: Top;
                      Padding: (Horizontal: 14, Vertical: 10);
                      Group { Anchor: (Height: 6); }
                      ItemIcon #TileIcon7 { Anchor: (Width: 28, Height: 28); }
                      Group { Anchor: (Height: 8); }
                      Label #TileTitle7 {
                        Text: "Module";
                        Anchor: (Left: 0, Right: 0, Height: 20);
                        Style: (FontSize: 16, TextColor: $C.@ColorDefault, RenderBold: true, HorizontalAlignment: Start, VerticalAlignment: Center);
                      }
                      Group { Anchor: (Height: 4); }
                      Label #TileDesc7 {
                        Text: "Description";
                        Anchor: (Left: 0, Right: 0, Height: 30);
                        Style: (FontSize: 12, TextColor: $C.@ColorDefaultLabel, HorizontalAlignment: Start, VerticalAlignment: Start, Wrap: true);
                      }
                    }
                  }
                }
                Group { Anchor: (Width: 16); }
                Group #Slot8 {
                  FlexWeight: 1;
                  Button #TileBtn8 {
                    Anchor: (Full: 0);
                    LayoutMode: Full;
                    Style: (
                      Default:  (Background: @BgSurface),
                      Hovered:  (Background: @TileHoverBorder),
                      Pressed:  (Background: #b8862e),
                      Disabled: (Background: #1a2030)
                    );
                    Group #TileInner8 {
                      Anchor: (Full: 2);
                      Background: @BgSurface;
                      LayoutMode: Top;
                      Padding: (Horizontal: 14, Vertical: 10);
                      Group { Anchor: (Height: 6); }
                      ItemIcon #TileIcon8 { Anchor: (Width: 28, Height: 28); }
                      Group { Anchor: (Height: 8); }
                      Label #TileTitle8 {
                        Text: "Module";
                        Anchor: (Left: 0, Right: 0, Height: 20);
                        Style: (FontSize: 16, TextColor: $C.@ColorDefault, RenderBold: true, HorizontalAlignment: Start, VerticalAlignment: Center);
                      }
                      Group { Anchor: (Height: 4); }
                      Label #TileDesc8 {
                        Text: "Description";
                        Anchor: (Left: 0, Right: 0, Height: 30);
                        Style: (FontSize: 12, TextColor: $C.@ColorDefaultLabel, HorizontalAlignment: Start, VerticalAlignment: Start, Wrap: true);
                      }
                    }
                  }
                }
              }
            }

            // Footer
            Group #Footer {
              Padding: (Top: 10);
              Anchor: (Left: 0, Right: 0, Height: 20);
              LayoutMode: Center;

              Label #FooterText {
                Text: "Press ESC to close";
                Style: (FontSize: 13, TextColor: @ColorTextMuted, HorizontalAlignment: Center, VerticalAlignment: Center);
              }
            }
          }
        }
      }
    }
  }
}
