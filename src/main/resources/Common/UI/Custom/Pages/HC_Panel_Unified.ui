      // ===== ALLOCATE SECTION (for stat allocation) =====
      Group #AllocateSection {
        Visible: false;
        LayoutMode: Top;

        // Header with available points
        Group #AllocateHeader {
          Anchor: (Height: 50);
          LayoutMode: Top;

          Group {
            LayoutMode: Left;
            Anchor: (Height: 22);

            Label {
              Text: "Available Points:";
              Anchor: (Width: 120);
              Style: (FontSize: 13, TextColor: @TextSecondary, VerticalAlignment: Center);
            }

            Label #AvailablePointsValue {
              Text: "0";
              Anchor: (Width: 40);
              Style: (FontSize: 16, TextColor: #ffd700, RenderBold: true, VerticalAlignment: Center);
            }

            Group { FlexWeight: 1; }

            Label {
              Text: "Total Allocated:";
              Anchor: (Width: 100);
              Style: (FontSize: 11, TextColor: @TextSecondary, VerticalAlignment: Center, HorizontalAlignment: End);
            }

            Label #TotalAllocatedValue {
              Text: "0";
              Anchor: (Width: 30);
              Style: (FontSize: 11, TextColor: @TextPrimary, RenderBold: true, VerticalAlignment: Center);
            }
          }

          Group { Anchor: (Height: 1); Background: @Border; }
          Group { Anchor: (Height: 12); }
        }

        // STRENGTH Card
        Group #AllocateRow0 {
          Anchor: (Height: 55);
          LayoutMode: Top;
          Background: @BgCard;
          Padding: (Full: 10);

          Group {
            LayoutMode: Left;
            Anchor: (Height: 20);

            Label #AllocLabel0 { Text: "STRENGTH"; Anchor: (Width: 100); Style: (FontSize: 12, TextColor: @ColorStr, RenderBold: true, VerticalAlignment: Center); }
            Label #AllocValue0 { Text: "10"; Anchor: (Width: 35); Style: (FontSize: 14, TextColor: @TextPrimary, RenderBold: true, VerticalAlignment: Center); }
            Label #AllocAllocated0 { Text: "(+0 allocated)"; Anchor: (Width: 100); Style: (FontSize: 10, TextColor: @TextSecondary, VerticalAlignment: Center); }

            Group { FlexWeight: 1; }

            TextButton #AllocBtn0Add1 { Text: "+1"; Anchor: (Width: 40, Height: 22); Style: @AllocButtonStyle; }
            Group { Anchor: (Width: 6); }
            TextButton #AllocBtn0Add5 { Text: "+5"; Anchor: (Width: 40, Height: 22); Style: @AllocButtonStyle; }
          }

          Label #AllocDesc0 {
            Text: "Increases melee attack power (+2 AP per point)";
            Anchor: (Height: 16);
            Style: (FontSize: 10, TextColor: #555555);
          }
        }

        Group { Anchor: (Height: 6); }

        // AGILITY Card
        Group #AllocateRow1 {
          Anchor: (Height: 55);
          LayoutMode: Top;
          Background: @BgCard;
          Padding: (Full: 10);

          Group {
            LayoutMode: Left;
            Anchor: (Height: 20);

            Label #AllocLabel1 { Text: "AGILITY"; Anchor: (Width: 100); Style: (FontSize: 12, TextColor: @ColorAgi, RenderBold: true, VerticalAlignment: Center); }
            Label #AllocValue1 { Text: "10"; Anchor: (Width: 35); Style: (FontSize: 14, TextColor: @TextPrimary, RenderBold: true, VerticalAlignment: Center); }
            Label #AllocAllocated1 { Text: "(+0 allocated)"; Anchor: (Width: 100); Style: (FontSize: 10, TextColor: @TextSecondary, VerticalAlignment: Center); }

            Group { FlexWeight: 1; }

            TextButton #AllocBtn1Add1 { Text: "+1"; Anchor: (Width: 40, Height: 22); Style: @AllocButtonStyle; }
            Group { Anchor: (Width: 6); }
            TextButton #AllocBtn1Add5 { Text: "+5"; Anchor: (Width: 40, Height: 22); Style: @AllocButtonStyle; }
          }

          Label #AllocDesc1 {
            Text: "Increases ranged attack power and critical strike chance";
            Anchor: (Height: 16);
