      // ===== HONOR STATS GRID (This Week / Lifetime side by side) =====
      Group #HonorStatsGrid {
        Anchor: (Height: 95);
        LayoutMode: Left;
        Visible: false;

        // THIS WEEK Column
        Group #ThisWeekCard {
          FlexWeight: 1;
          LayoutMode: Top;
          Background: @BgCard;
          Padding: (Full: 14);

          Label {
            Text: "THIS WEEK";
            Anchor: (Height: 20);
            Style: (FontSize: 12, TextColor: @TextSecondary, RenderBold: true, LetterSpacing: 1);
          }

          Group {
            LayoutMode: Left;
            Anchor: (Height: 22);

            Label { Text: "Honor:"; Anchor: (Width: 48); Style: (FontSize: 14, TextColor: @TextSecondary, VerticalAlignment: Center); }
            Label #WeeklyHonorValue { Text: "0"; FlexWeight: 1; Style: (FontSize: 14, TextColor: #ffd700, RenderBold: true, VerticalAlignment: Center); }
          }

          Group {
            LayoutMode: Left;
            Anchor: (Height: 22);

            Label { Text: "Kills:"; Anchor: (Width: 48); Style: (FontSize: 14, TextColor: @TextSecondary, VerticalAlignment: Center); }
            Label #WeeklyKillsValue { Text: "0"; FlexWeight: 1; Style: (FontSize: 14, TextColor: @TextPrimary, VerticalAlignment: Center); }
          }

          Group {
            LayoutMode: Left;
            Anchor: (Height: 22);

            Label { Text: "Bracket:"; Anchor: (Width: 48); Style: (FontSize: 14, TextColor: @TextSecondary, VerticalAlignment: Center); }
            Label #CurrentBracketValue { Text: "-"; Anchor: (Width: 16); Style: (FontSize: 14, TextColor: #4aff7f, RenderBold: true, VerticalAlignment: Center); }
            Label #BracketRewardLabel { Text: ""; FlexWeight: 1; Style: (FontSize: 13, TextColor: #4a7c59, VerticalAlignment: Center); }
          }
        }

        Group { Anchor: (Width: 8); }

        // LIFETIME Column
        Group #LifetimeCard {
          FlexWeight: 1;
          LayoutMode: Top;
          Background: @BgCard;
          Padding: (Full: 14);

          Label {
            Text: "LIFETIME";
            Anchor: (Height: 20);
            Style: (FontSize: 12, TextColor: @TextSecondary, RenderBold: true, LetterSpacing: 1);
          }

          Group {
            LayoutMode: Left;
            Anchor: (Height: 22);

            Label { Text: "Kills:"; Anchor: (Width: 48); Style: (FontSize: 14, TextColor: @TextSecondary, VerticalAlignment: Center); }
            Label #TotalKillsValue { Text: "0"; FlexWeight: 1; Style: (FontSize: 14, TextColor: #e74c3c, RenderBold: true, VerticalAlignment: Center); }
          }

          Group {
            LayoutMode: Left;
            Anchor: (Height: 22);

            Label { Text: "Honor:"; Anchor: (Width: 48); Style: (FontSize: 14, TextColor: @TextSecondary, VerticalAlignment: Center); }
            Label #SpendableHonorValue { Text: "0"; FlexWeight: 1; Style: (FontSize: 14, TextColor: #ffd700, RenderBold: true, VerticalAlignment: Center); }
          }

          Label {
            Text: "(spendable currency)";
            Anchor: (Height: 18);
            Style: (FontSize: 12, TextColor: #555555);
          }
        }
      }

      Group #HonorSpacer1 { Anchor: (Height: 12); Visible: false; }

      // ===== NEXT RANK SECTION (full width) =====
      Group #NextRankSection {
        LayoutMode: Top;
        Background: @BgCard;
        Padding: (Full: 14);
        Visible: false;

        Group {
          LayoutMode: Left;
          Anchor: (Height: 22);

          Label { Text: "NEXT RANK"; Anchor: (Width: 80); Style: (FontSize: 12, TextColor: @TextSecondary, RenderBold: true, LetterSpacing: 1, VerticalAlignment: Center); }
          Label #NextRankLabel { Text: ""; FlexWeight: 1; Style: (FontSize: 14, TextColor: #9932cc, RenderBold: true, VerticalAlignment: Center); }
        }

        Group {
          LayoutMode: Left;
          Anchor: (Height: 22);

          Label #RPNeededLabel { Text: ""; FlexWeight: 1; Style: (FontSize: 14, TextColor: @TextSecondary, VerticalAlignment: Center); }
        }
      }

      Group #HonorSpacer2 { Anchor: (Height: 12); Visible: false; }

      // ===== HONOR INFO ROW (Reset Timer / Decay Warning) =====
      Group #HonorInfoRow {
        Anchor: (Height: 56);
        LayoutMode: Left;
        Visible: false;

        // Reset Timer Card
        Group #ResetTimerCard {
          FlexWeight: 1;
          LayoutMode: Top;
          Background: @BgCard;
          Padding: (Full: 14);

          Label {
            Text: "WEEKLY RESET";
            Anchor: (Height: 18);
            Style: (FontSize: 12, TextColor: @TextSecondary, RenderBold: true, LetterSpacing: 1);
          }

          Label #ResetTimerLabel {
            Text: "";
            Anchor: (Height: 20);
            Style: (FontSize: 16, TextColor: #ff9f43, RenderBold: true, VerticalAlignment: Center);
          }
        }

        Group { Anchor: (Width: 8); }

        // Decay Warning Card
        Group #DecayCard {
          FlexWeight: 1;
          LayoutMode: Top;
          Background: @BgCard;
          Padding: (Full: 14);

          Label {
            Text: "ESTIMATED DECAY";
            Anchor: (Height: 18);
            Style: (FontSize: 12, TextColor: @TextSecondary, RenderBold: true, LetterSpacing: 1);
          }

          Label #DecayWarningLabel {
            Text: "";
            Anchor: (Height: 20);
            Style: (FontSize: 16, TextColor: #ff6b6b, RenderBold: true, VerticalAlignment: Center);
          }
        }
      }

      Group #HonorSpacer3 { Anchor: (Height: 12); Visible: false; }

      // ===== BRACKET PROGRESS SECTION (copied from HC_Honor_Panel.ui) =====
      Group #BracketProgressSection {
        LayoutMode: Top;
        Background: @BgCard;
        Padding: (Full: 14);
        Visible: false;

        Group {
          LayoutMode: Left;
          Anchor: (Height: 18);

          Label { Text: "BRACKET PROGRESS"; FlexWeight: 1; Style: (FontSize: 12, TextColor: @TextSecondary, RenderBold: true, LetterSpacing: 1, VerticalAlignment: Center); }
          Label #NextBracketLabel { Text: "1,150 to Bracket 5"; Anchor: (Width: 120); Style: (FontSize: 13, TextColor: #6b8e23, HorizontalAlignment: End, VerticalAlignment: Center); }
        }

        Group { Anchor: (Height: 4); }

        Group #BracketProgressBg {
          Anchor: (Height: 10);
          Background: #0a1119;
          LayoutMode: Left;

          Group #BracketProgressBar {
            Anchor: (Width: 0, Height: 10);
            Background: #4a7c59;
          }
        }
      }

      // ===== NEW HONOR UI: HERO RANK SECTION (120px) =====
      Group #HonorHeroSection {
        Anchor: (Height: 130);
        LayoutMode: Top;
        Visible: false;

        Group {
          LayoutMode: Left;

          // Large Rank Emblem with tier-colored glowing border (90x90)
          Group #HonorEmblemOuter {
            Anchor: (Width: 95, Height: 105);
            Background: #808080;
            Padding: (Full: 3);
            LayoutMode: Top;

            Group #HonorEmblemInner {
              FlexWeight: 1;
              Background: #0d1117;
              LayoutMode: Top;
              Padding: (Full: 10);

              Label {
                Text: "RANK";
                Anchor: (Height: 12);
                Style: (FontSize: 11, TextColor: @TextSecondary, RenderBold: true, LetterSpacing: 1, HorizontalAlignment: Center);
              }

              Label #HonorRankNumber {
                Text: "0";
                FlexWeight: 1;
                Style: (FontSize: 52, TextColor: #808080, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center);
              }
            }
          }

          Group { Anchor: (Width: 16); }

          // Title, player info, and progress bar
          Group {
            FlexWeight: 1;
            LayoutMode: Top;
            Padding: (Top: 2);

            // Rank title (large, colored by tier, uppercase)
            Label #HonorRankTitle {
              Text: "UNRANKED";
              Anchor: (Height: 32);
              Style: (FontSize: 28, TextColor: #808080, RenderBold: true, LetterSpacing: 2);
            }

            // Player name and faction tag row
            Group {
              LayoutMode: Left;
              Anchor: (Height: 20);

              Label #HonorFactionTag {
                Text: "";
                Anchor: (Width: 55);
                Style: (FontSize: 15, TextColor: #4169e1, RenderBold: true, VerticalAlignment: Center);
              }

              Label #HonorPlayerName {
                Text: "";
                FlexWeight: 1;
                Style: (FontSize: 15, TextColor: @TextPrimary, VerticalAlignment: Center);
              }
            }

            Group { Anchor: (Height: 8); }

            // Full-width tier-colored progress bar
            Group #HonorHeroProgressBg {
              Anchor: (Height: 20);
              Background: #0a1119;
              LayoutMode: Left;

              Group #HonorHeroProgressBar {
                Anchor: (Width: 0, Height: 20);
                Background: #808080;
              }
            }

            Group { Anchor: (Height: 6); }

            // RP label showing "X / Y RP to [NextRank]"
            Label #HonorRPToNextRank {
              Text: "0 / 2,000 RP to Private";
              Anchor: (Height: 20);
              Style: (FontSize: 14, TextColor: @TextSecondary, VerticalAlignment: Center);
            }
          }
        }

        Group { Anchor: (Height: 1); Background: @Border; }
        Group { Anchor: (Height: 18); }
      }

      // ===== NEW HONOR UI: WEEKLY PERFORMANCE CARD (100px) =====
      Group #HonorWeeklyCard {
        LayoutMode: Top;
        Background: @BgCard;
        Padding: (Full: 16);
        Visible: false;

        // Header row with title and reset timer
        Group {
          LayoutMode: Left;
          Anchor: (Height: 20);

          Label {
            Text: "WEEKLY PERFORMANCE";
            FlexWeight: 1;
            Style: (FontSize: 12, TextColor: @TextSecondary, RenderBold: true, LetterSpacing: 1, VerticalAlignment: Center);
          }

          Label #HonorResetTimer {
            Text: "6d 12h";
            Anchor: (Width: 80);
            Style: (FontSize: 13, TextColor: #ff9f43, RenderBold: true, HorizontalAlignment: End, VerticalAlignment: Center);
          }
        }

        Group { Anchor: (Height: 8); }

        // Main stats row: Bracket | Weekly Honor | Kills | Avg
        Group {
          LayoutMode: Left;
          Anchor: (Height: 38);

          // Bracket section
          Group {
            Anchor: (Width: 90);
            LayoutMode: Top;

            Label {
              Text: "BRACKET";
              Anchor: (Height: 12);
              Style: (FontSize: 11, TextColor: #555555, LetterSpacing: 1);
            }

            Group {
              LayoutMode: Left;
              Anchor: (Height: 26);

              Label #HonorBracketValue {
                Text: "-";
                Anchor: (Width: 35);
                Style: (FontSize: 28, TextColor: #555555, RenderBold: true, VerticalAlignment: Center);
              }

              Label #HonorBracketRP {
                Text: "+0 RP";
                FlexWeight: 1;
                Style: (FontSize: 14, TextColor: #4a7c59, RenderBold: true, VerticalAlignment: Center);
              }
            }
          }

          // Divider
          Group { Anchor: (Width: 1, Height: 30); Background: #2a2f3a; }
          Group { Anchor: (Width: 12); }

          // Weekly Honor section
          Group {
            Anchor: (Width: 100);
            LayoutMode: Top;

            Label {
              Text: "HONOR";
              Anchor: (Height: 12);
              Style: (FontSize: 11, TextColor: #555555, LetterSpacing: 1);
            }

            Label #HonorWeeklyValue {
              Text: "0";
              Anchor: (Height: 26);
              Style: (FontSize: 24, TextColor: #ffd700, RenderBold: true, VerticalAlignment: Center);
            }
          }

          // Divider
          Group { Anchor: (Width: 1, Height: 30); Background: #2a2f3a; }
          Group { Anchor: (Width: 12); }

          // Kills section
          Group {
            Anchor: (Width: 70);
            LayoutMode: Top;

            Label {
              Text: "KILLS";
              Anchor: (Height: 12);
              Style: (FontSize: 11, TextColor: #555555, LetterSpacing: 1);
            }

            Label #HonorWeeklyKills {
              Text: "0";
              Anchor: (Height: 26);
              Style: (FontSize: 24, TextColor: #e74c3c, RenderBold: true, VerticalAlignment: Center);
            }
          }

          // Divider
          Group { Anchor: (Width: 1, Height: 30); Background: #2a2f3a; }
          Group { Anchor: (Width: 12); }

          // Average honor/kill section
          Group {
            FlexWeight: 1;
            LayoutMode: Top;

            Label {
              Text: "AVG/KILL";
              Anchor: (Height: 12);
              Style: (FontSize: 11, TextColor: #555555, LetterSpacing: 1);
            }

            Label #HonorAvgPerKill {
              Text: "-";
              Anchor: (Height: 26);
              Style: (FontSize: 20, TextColor: #8fa4b8, RenderBold: true, VerticalAlignment: Center);
            }
          }
        }

        Group { Anchor: (Height: 6); }

        // Bracket progress bar at bottom
        Group {
          LayoutMode: Left;
          Anchor: (Height: 18);

          Label #HonorBracketTarget {
            Text: "Next: Bracket 9";
            Anchor: (Width: 100);
            Style: (FontSize: 12, TextColor: #6b8e23, VerticalAlignment: Center);
          }

          Group #HonorBracketProgressBg {
            FlexWeight: 1;
            Anchor: (Height: 10);
            Background: #0a1119;
            LayoutMode: Left;

            Group #HonorBracketProgressBar {
              Anchor: (Width: 0, Height: 10);
              Background: #4a7c59;
            }
          }

          Label #HonorBracketReward {
            Text: "+2,000 RP";
            Anchor: (Width: 70);
            Style: (FontSize: 12, TextColor: #4aff7f, RenderBold: true, HorizontalAlignment: End, VerticalAlignment: Center);
          }
        }
      }

      Group #HonorWeeklyCardSpacer { Anchor: (Height: 12); Visible: false; }

      // ===== NEW HONOR UI: CURRENCY & PROGRESSION ROW (80px) =====
      Group #HonorCurrencyProgressRow {
        Anchor: (Height: 90);
        LayoutMode: Left;
        Visible: false;

        // Spendable Honor Card (left)
        Group {
          FlexWeight: 1;
          LayoutMode: Top;
          Background: @BgCard;
          Padding: (Full: 16);

          Label {
            Text: "SPENDABLE HONOR";
            Anchor: (Height: 18);
            Style: (FontSize: 12, TextColor: @TextSecondary, RenderBold: true, LetterSpacing: 1);
          }

          Group { Anchor: (Height: 4); }

          Label #HonorSpendableValue {
            Text: "0";
            FlexWeight: 1;
            Style: (FontSize: 32, TextColor: #ffd700, RenderBold: true, VerticalAlignment: Center);
          }

          Label {
            Text: "currency for shop";
            Anchor: (Height: 18);
            Style: (FontSize: 12, TextColor: #555555);
          }
        }

        Group { Anchor: (Width: 10); }

        // Next Rank Card (right)
        Group {
          FlexWeight: 1;
          LayoutMode: Top;
          Background: @BgCard;
          Padding: (Full: 16);

          Label {
            Text: "NEXT RANK";
            Anchor: (Height: 18);
            Style: (FontSize: 12, TextColor: @TextSecondary, RenderBold: true, LetterSpacing: 1);
          }

          Group { Anchor: (Height: 4); }

          Label #HonorNextRankTitle {
            Text: "Private";
            FlexWeight: 1;
            Style: (FontSize: 22, TextColor: #c0c0c0, RenderBold: true, VerticalAlignment: Center);
          }

          Label #HonorRPNeeded {
            Text: "2,000 RP needed";
            Anchor: (Height: 18);
            Style: (FontSize: 13, TextColor: @TextSecondary);
          }
        }
      }

      Group #HonorCurrencyProgressSpacer { Anchor: (Height: 12); Visible: false; }

      // ===== NEW HONOR UI: ACCOUNT STATS & DECAY ROW (70px) =====
      Group #HonorAccountDecayRow {
        Anchor: (Height: 80);
        LayoutMode: Left;
        Visible: false;

        // Lifetime Stats Card (left)
        Group {
          FlexWeight: 1;
          LayoutMode: Top;
          Background: @BgCard;
          Padding: (Full: 14);

          Label {
            Text: "ACCOUNT STATS";
            Anchor: (Height: 18);
            Style: (FontSize: 12, TextColor: @TextSecondary, RenderBold: true, LetterSpacing: 1);
          }

          Group { Anchor: (Height: 6); }

          Group {
            LayoutMode: Left;
            Anchor: (Height: 26);

            Label { Text: "Lifetime Kills:"; Anchor: (Width: 80); Style: (FontSize: 13, TextColor: @TextSecondary, VerticalAlignment: Center); }
            Label #HonorLifetimeKills { Text: "0"; Anchor: (Width: 55); Style: (FontSize: 16, TextColor: #e74c3c, RenderBold: true, VerticalAlignment: Center); }
            Label { Text: "Highest:"; Anchor: (Width: 50); Style: (FontSize: 13, TextColor: @TextSecondary, VerticalAlignment: Center); }
            Label #HonorHighestRank { Text: "R0"; FlexWeight: 1; Style: (FontSize: 16, TextColor: @TextGold, RenderBold: true, VerticalAlignment: Center); }
          }
        }

        Group { Anchor: (Width: 10); }

        // Decay Warning Card (right, red-tinted)
        Group {
          Anchor: (Width: 145);
          LayoutMode: Top;
          Background: #2a1a1a;
          Padding: (Full: 14);

          Group {
            LayoutMode: Left;
            Anchor: (Height: 18);

            Label {
              Text: "DECAY WARNING";
              FlexWeight: 1;
              Style: (FontSize: 12, TextColor: #ff6b6b, RenderBold: true, LetterSpacing: 1, VerticalAlignment: Center);
            }

            Label {
              Text: "!";
              Anchor: (Width: 16);
              Style: (FontSize: 14, TextColor: #ff6b6b, HorizontalAlignment: End, VerticalAlignment: Center);
            }
          }

          Group { Anchor: (Height: 6); }

          Group {
            LayoutMode: Left;
            Anchor: (Height: 26);

            Label #HonorDecayAmount {
              Text: "-0 RP";
              Anchor: (Width: 80);
              Style: (FontSize: 20, TextColor: #ff6b6b, RenderBold: true, VerticalAlignment: Center);
            }

            Label {
              Text: "(20%)";
              FlexWeight: 1;
              Style: (FontSize: 13, TextColor: #8b4444, VerticalAlignment: Center);
            }
          }
        }
      }

      // ===== NEW ATTRIBUTES UI: HERO CLASS SECTION =====
      Group #AttrHeroSection {
        Anchor: (Height: 110);
        LayoutMode: Top;
        Visible: false;

        Group {
          LayoutMode: Left;

          // Class emblem with colored border
          Group #AttrClassEmblem {
            Anchor: (Width: 85, Height: 95);
            Background: #d4af37;
            Padding: (Full: 3);
            LayoutMode: Top;

            Group {
              FlexWeight: 1;
              Background: #0d1117;
              LayoutMode: Top;
              Padding: (Full: 8);

              Label {
                Text: "LVL";
                Anchor: (Height: 12);
                Style: (FontSize: 11, TextColor: @TextSecondary, RenderBold: true, LetterSpacing: 1, HorizontalAlignment: Center);
              }

              Label #AttrLevelNumber {
                Text: "1";
                FlexWeight: 1;
                Style: (FontSize: 40, TextColor: #d4af37, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center);
              }
            }
          }

          Group { Anchor: (Width: 14); }

          // Class name and player info
          Group {
            FlexWeight: 1;
            LayoutMode: Top;
            Padding: (Top: 4);

            // Class name (large)
            Label #AttrClassName {
              Text: "ADVENTURER";
              Anchor: (Height: 32);
              Style: (FontSize: 26, TextColor: #d4af37, RenderBold: true, LetterSpacing: 2);
            }

            // Player name with faction tag
            Group {
              LayoutMode: Left;
              Anchor: (Height: 20);

              Label #AttrFactionTag {
                Text: "";
                Anchor: (Width: 55);
                Style: (FontSize: 15, TextColor: #4169e1, RenderBold: true, VerticalAlignment: Center);
              }

              Label #AttrPlayerName {
                Text: "";
                FlexWeight: 1;
                Style: (FontSize: 15, TextColor: @TextPrimary, VerticalAlignment: Center);
              }
            }

            Group { Anchor: (Height: 8); }

            // Stat points available banner
            Group #AttrPointsBanner {
              Anchor: (Height: 28);
              Background: #2a3a2a;
              LayoutMode: Left;
              Padding: (Left: 10, Right: 10);
              Visible: false;

              Label {
                Text: "STAT POINTS AVAILABLE:";
                FlexWeight: 1;
                Style: (FontSize: 13, TextColor: #4aff7f, RenderBold: true, LetterSpacing: 1, VerticalAlignment: Center);
              }

              Label #AttrPointsValue {
                Text: "0";
                Anchor: (Width: 30);
                Style: (FontSize: 16, TextColor: #4aff7f, RenderBold: true, HorizontalAlignment: End, VerticalAlignment: Center);
              }
            }
          }
        }

        Group { Anchor: (Height: 1); Background: @Border; }
        Group { Anchor: (Height: 18); }
      }

      // ===== NEW ATTRIBUTES UI: PRIMARY STATS GRID =====
      Group #PrimaryAttributesCard {
        LayoutMode: Top;
        Visible: false;

        Label {
          Text: "PRIMARY ATTRIBUTES";
          Anchor: (Height: 22);
          Style: (FontSize: 13, TextColor: @TextSecondary, RenderBold: true, LetterSpacing: 1);
        }

        Group { Anchor: (Height: 8); }

        // Two-column grid for attributes
        Group {
          Anchor: (Height: 155);
          LayoutMode: Left;

          // Left column: STR, INT, VIT
          Group {
            FlexWeight: 1;
            LayoutMode: Top;

            // STR
            Group {
              Anchor: (Height: 48);
              Background: @BgCard;
              LayoutMode: Left;
              Padding: (Full: 10);

              Group {
                Anchor: (Width: 38, Height: 26);
                Background: #c0392b;
                LayoutMode: Top;
                Padding: (Full: 2);

                Label { Text: "STR"; FlexWeight: 1; Style: (FontSize: 13, TextColor: #ffffff, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center); }
              }

              Group { Anchor: (Width: 8); }

              Group {
                FlexWeight: 1;
                LayoutMode: Top;

                Label #AttrValue0 { Text: "10"; Anchor: (Height: 20); Style: (FontSize: 16, TextColor: @ColorStr, RenderBold: true, VerticalAlignment: Center); }
                Label #AttrDerived0 { Text: "+20 Melee AP"; Anchor: (Height: 12); Style: (FontSize: 12, TextColor: @TextGreen, VerticalAlignment: Center); }
              }
            }

            Group { Anchor: (Height: 4); }

            // INT
            Group {
              Anchor: (Height: 48);
              Background: @BgCard;
              LayoutMode: Left;
              Padding: (Full: 10);

              Group {
                Anchor: (Width: 38, Height: 26);
                Background: #8e44ad;
                LayoutMode: Top;
                Padding: (Full: 2);

                Label { Text: "INT"; FlexWeight: 1; Style: (FontSize: 13, TextColor: #ffffff, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center); }
              }

              Group { Anchor: (Width: 8); }

              Group {
                FlexWeight: 1;
                LayoutMode: Top;

                Label #AttrValue2 { Text: "10"; Anchor: (Height: 20); Style: (FontSize: 16, TextColor: @ColorInt, RenderBold: true, VerticalAlignment: Center); }
                Label #AttrDerived2 { Text: "+20 SP, +150 MP"; Anchor: (Height: 12); Style: (FontSize: 12, TextColor: @TextGreen, VerticalAlignment: Center); }
              }
            }

            Group { Anchor: (Height: 4); }

            // VIT
            Group {
              Anchor: (Height: 48);
              Background: @BgCard;
              LayoutMode: Left;
              Padding: (Full: 10);

              Group {
                Anchor: (Width: 38, Height: 26);
                Background: #27ae60;
                LayoutMode: Top;
                Padding: (Full: 2);

                Label { Text: "VIT"; FlexWeight: 1; Style: (FontSize: 13, TextColor: #ffffff, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center); }
              }

              Group { Anchor: (Width: 8); }

              Group {
                FlexWeight: 1;
                LayoutMode: Top;

                Label #AttrValue4 { Text: "10"; Anchor: (Height: 20); Style: (FontSize: 16, TextColor: @ColorVit, RenderBold: true, VerticalAlignment: Center); }
                Label #AttrDerived4 { Text: "+100 HP"; Anchor: (Height: 12); Style: (FontSize: 12, TextColor: @TextGreen, VerticalAlignment: Center); }
              }
            }
          }

          Group { Anchor: (Width: 8); }

          // Right column: AGI, SPI
          Group {
            FlexWeight: 1;
            LayoutMode: Top;

            // AGI
            Group {
              Anchor: (Height: 48);
              Background: @BgCard;
              LayoutMode: Left;
              Padding: (Full: 10);

              Group {
                Anchor: (Width: 38, Height: 26);
                Background: #16a085;
                LayoutMode: Top;
                Padding: (Full: 2);

                Label { Text: "AGI"; FlexWeight: 1; Style: (FontSize: 13, TextColor: #ffffff, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center); }
              }

              Group { Anchor: (Width: 8); }

              Group {
                FlexWeight: 1;
                LayoutMode: Top;

                Label #AttrValue1 { Text: "10"; Anchor: (Height: 20); Style: (FontSize: 16, TextColor: @ColorAgi, RenderBold: true, VerticalAlignment: Center); }
                Label #AttrDerived1 { Text: "+20 RAP, +0.5% Crit"; Anchor: (Height: 12); Style: (FontSize: 12, TextColor: @TextGreen, VerticalAlignment: Center); }
              }
            }

            Group { Anchor: (Height: 4); }

            // SPI
            Group {
              Anchor: (Height: 48);
              Background: @BgCard;
              LayoutMode: Left;
              Padding: (Full: 10);

              Group {
                Anchor: (Width: 38, Height: 26);
                Background: #2980b9;
                LayoutMode: Top;
                Padding: (Full: 2);

                Label { Text: "SPI"; FlexWeight: 1; Style: (FontSize: 13, TextColor: #ffffff, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center); }
              }

              Group { Anchor: (Width: 8); }

              Group {
                FlexWeight: 1;
                LayoutMode: Top;

                Label #AttrValue3 { Text: "10"; Anchor: (Height: 20); Style: (FontSize: 16, TextColor: @ColorSpi, RenderBold: true, VerticalAlignment: Center); }
                Label #AttrDerived3 { Text: "+5 HP/t, +10 MP/t"; Anchor: (Height: 12); Style: (FontSize: 12, TextColor: @TextGreen, VerticalAlignment: Center); }
              }
            }

            Group { Anchor: (Height: 4); }

            // Empty spacer to match left column
            Group { Anchor: (Height: 42); }
          }
        }
      }

      Group #AttrPrimaryCardSpacer { Anchor: (Height: 10); Visible: false; }

      // ===== NEW ATTRIBUTES UI: COMBAT & RESOURCES ROW =====
      Group #CombatResourcesRow {
        Anchor: (Height: 130);
        LayoutMode: Left;
        Visible: false;

        // Combat Stats Card
        Group {
          FlexWeight: 1;
          LayoutMode: Top;
          Background: @BgCard;
          Padding: (Full: 16);

          Label {
            Text: "BONUS DAMAGE";
            Anchor: (Height: 20);
            Style: (FontSize: 12, TextColor: @TextSecondary, RenderBold: true, LetterSpacing: 1);
          }

          Group { Anchor: (Height: 6); }

          // Main combat stats in 2x2 grid - shows bonus damage per hit + AP
          Group {
            LayoutMode: Left;
            Anchor: (Height: 36);

            Group {
              FlexWeight: 1;
              LayoutMode: Top;

              Label { Text: "MELEE"; Anchor: (Height: 10); Style: (FontSize: 10, TextColor: #555555, LetterSpacing: 1); }
              Label #MeleeAPValue { Text: "+0"; Anchor: (Height: 18); Style: (FontSize: 16, TextColor: @ColorStr, RenderBold: true); }
              Label #MeleeAPDetail { Text: "0 AP"; Anchor: (Height: 10); Style: (FontSize: 9, TextColor: #555555); }
            }

            Group {
              FlexWeight: 1;
              LayoutMode: Top;

              Label { Text: "RANGED"; Anchor: (Height: 10); Style: (FontSize: 10, TextColor: #555555, LetterSpacing: 1); }
              Label #RangedAPValue { Text: "+0"; Anchor: (Height: 18); Style: (FontSize: 16, TextColor: @ColorAgi, RenderBold: true); }
              Label #RangedAPDetail { Text: "0 AP"; Anchor: (Height: 10); Style: (FontSize: 9, TextColor: #555555); }
            }
          }

          Group { Anchor: (Height: 4); }

          Group {
            LayoutMode: Left;
            Anchor: (Height: 36);

            Group {
              FlexWeight: 1;
              LayoutMode: Top;

              Label { Text: "SPELL"; Anchor: (Height: 10); Style: (FontSize: 10, TextColor: #555555, LetterSpacing: 1); }
              Label #SpellPowerValue { Text: "+0"; Anchor: (Height: 18); Style: (FontSize: 16, TextColor: @ColorInt, RenderBold: true); }
              Label #SpellPowerDetail { Text: "0 SP"; Anchor: (Height: 10); Style: (FontSize: 9, TextColor: #555555); }
            }

            Group {
              FlexWeight: 1;
              LayoutMode: Top;

              Label { Text: "CRIT"; Anchor: (Height: 10); Style: (FontSize: 10, TextColor: #555555, LetterSpacing: 1); }
              Label #CritChanceValue { Text: "0%"; Anchor: (Height: 18); Style: (FontSize: 16, TextColor: @TextGold, RenderBold: true); }
            }
          }
        }

        Group { Anchor: (Width: 8); }

        // Resources Card - two columns: HP (left) and MP (right)
        Group {
          FlexWeight: 1;
          LayoutMode: Top;
          Background: @BgCard;
          Padding: (Full: 16);

          Label {
            Text: "RESOURCES";
            Anchor: (Height: 20);
            Style: (FontSize: 12, TextColor: @TextSecondary, RenderBold: true, LetterSpacing: 1);
          }

          Group { Anchor: (Height: 4); }

          // Two-column layout: HP left, MP right
          Group {
            LayoutMode: Left;
            FlexWeight: 1;

            // HP Column
            Group {
              FlexWeight: 1;
              LayoutMode: Top;

              Label { Text: "HP"; Anchor: (Height: 14); Style: (FontSize: 13, TextColor: #e74c3c, RenderBold: true); }
              Label #MaxHPValue { Text: "0"; Anchor: (Height: 16); Style: (FontSize: 15, TextColor: #e74c3c, RenderBold: true); }
              Group { Anchor: (Height: 2); }
              Label #HPLineBase { Text: ""; Anchor: (Height: 12); Style: (FontSize: 10, TextColor: #888888); }
              Label #HPLineVit { Text: ""; Anchor: (Height: 12); Style: (FontSize: 10, TextColor: #888888); }
              Label #HPLineClass { Text: ""; Anchor: (Height: 12); Style: (FontSize: 10, TextColor: #888888); }
              Label #HPLineRegen { Text: ""; Anchor: (Height: 12); Style: (FontSize: 10, TextColor: #555555); }
            }

            Group { Anchor: (Width: 8); }

            // MP Column
            Group {
              FlexWeight: 1;
              LayoutMode: Top;

              Label { Text: "MP"; Anchor: (Height: 14); Style: (FontSize: 13, TextColor: #3498db, RenderBold: true); }
              Label #MaxMPValue { Text: "0"; Anchor: (Height: 16); Style: (FontSize: 15, TextColor: #3498db, RenderBold: true); }
              Group { Anchor: (Height: 2); }
              Label #MPLineBase { Text: ""; Anchor: (Height: 12); Style: (FontSize: 10, TextColor: #888888); }
              Label #MPLineInt { Text: ""; Anchor: (Height: 12); Style: (FontSize: 10, TextColor: #888888); }
              Label #MPLineRegen { Text: ""; Anchor: (Height: 12); Style: (FontSize: 10, TextColor: #555555); }
            }
          }
        }
      }

      Group #AttrCombatResourcesSpacer { Anchor: (Height: 10); Visible: false; }

      // ===== NEW ATTRIBUTES UI: DEFENSE & RESISTANCES =====
      Group #DefenseSection {
        Anchor: (Height: 85);
        LayoutMode: Left;
        Visible: false;

        // Armor Card
        Group {
          Anchor: (Width: 140);
          LayoutMode: Top;
          Background: @BgCard;
          Padding: (Full: 16);

          Label {
            Text: "ARMOR";
            Anchor: (Height: 18);
            Style: (FontSize: 12, TextColor: @TextSecondary, RenderBold: true, LetterSpacing: 1);
          }

          Group { Anchor: (Height: 4); }

          Label #ArmorValue {
            Text: "0";
            Anchor: (Height: 28);
            Style: (FontSize: 24, TextColor: #bdc3c7, RenderBold: true);
          }

          Label #ArmorReduction {
            Text: "0.0% reduction";
            Anchor: (Height: 18);
            Style: (FontSize: 12, TextColor: #555555);
          }
        }

        Group { Anchor: (Width: 8); }

        // Resistances Card
        Group {
          FlexWeight: 1;
          LayoutMode: Top;
          Background: @BgCard;
          Padding: (Full: 16);

          Label {
            Text: "RESISTANCES";
            Anchor: (Height: 18);
            Style: (FontSize: 12, TextColor: @TextSecondary, RenderBold: true, LetterSpacing: 1);
          }

          Group { Anchor: (Height: 6); }

          // Resistance icons row
          Group {
            LayoutMode: Left;
            Anchor: (Height: 32);

            // Fire
            Group {
              FlexWeight: 1;
              LayoutMode: Top;

              Label { Text: "FIRE"; Anchor: (Height: 10); Style: (FontSize: 10, TextColor: #ff6347, LetterSpacing: 1, HorizontalAlignment: Center); }
              Label #FireResValue { Text: "0"; Anchor: (Height: 22); Style: (FontSize: 14, TextColor: #ff6347, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center); }
            }

            // Ice
            Group {
              FlexWeight: 1;
              LayoutMode: Top;

              Label { Text: "ICE"; Anchor: (Height: 10); Style: (FontSize: 10, TextColor: #87ceeb, LetterSpacing: 1, HorizontalAlignment: Center); }
              Label #IceResValue { Text: "0"; Anchor: (Height: 22); Style: (FontSize: 14, TextColor: #87ceeb, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center); }
            }

            // Lightning
            Group {
              FlexWeight: 1;
              LayoutMode: Top;

              Label { Text: "LTNG"; Anchor: (Height: 10); Style: (FontSize: 10, TextColor: #ffd700, LetterSpacing: 1, HorizontalAlignment: Center); }
              Label #LightningResValue { Text: "0"; Anchor: (Height: 22); Style: (FontSize: 14, TextColor: #ffd700, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center); }
            }

            // Poison
            Group {
              FlexWeight: 1;
              LayoutMode: Top;

              Label { Text: "PSN"; Anchor: (Height: 10); Style: (FontSize: 10, TextColor: #32cd32, LetterSpacing: 1, HorizontalAlignment: Center); }
              Label #PoisonResValue { Text: "0"; Anchor: (Height: 22); Style: (FontSize: 14, TextColor: #32cd32, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center); }
            }

            // Magic
            Group {
              FlexWeight: 1;
              LayoutMode: Top;

              Label { Text: "MAG"; Anchor: (Height: 10); Style: (FontSize: 10, TextColor: #9370db, LetterSpacing: 1, HorizontalAlignment: Center); }
              Label #MagicResValue { Text: "0"; Anchor: (Height: 22); Style: (FontSize: 14, TextColor: #9370db, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center); }
            }
          }
        }
      }

      // ===== FACTIONS STATS SECTION (POWER + RANK + MEMBERS cards side by side) =====
      Group #FactionStatsSection {
        LayoutMode: Top;
        Visible: false;

        Group {
          Anchor: (Height: 120);
          LayoutMode: Left;

          // POWER Card
          Group #PowerStatCard {
            Anchor: (Width: 165);
            LayoutMode: Top;
            Background: @BgCard;

            Group { Anchor: (Height: 3); Background: #4FC3F7; }
            Group {
              FlexWeight: 1;
              LayoutMode: Top;
              Padding: (Left: 14, Right: 14, Top: 10, Bottom: 10);

              Group {
                LayoutMode: Left;
                Anchor: (Height: 20);

                Group { Anchor: (Width: 20, Height: 20); Background: #4FC3F7; LayoutMode: Center;
                  Label { Text: "P"; FlexWeight: 1; Style: (FontSize: 14, TextColor: #0a1119, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center); }
                }
                Group { Anchor: (Width: 6); }
                Label { Text: "POWER"; FlexWeight: 1; Style: (FontSize: 14, TextColor: #4FC3F7, RenderBold: true, LetterSpacing: 1, VerticalAlignment: Center); }
              }

              Label #PowerValue {
                Text: "0";
                Anchor: (Height: 42);
                Style: (FontSize: 34, TextColor: #ffffff, RenderBold: true);
              }

              Label #PowerDesc {
                Text: "claim strength";
                Anchor: (Height: 22);
                Style: (FontSize: 14, TextColor: #8fa4b8);
              }
            }
          }

          Group { Anchor: (Width: 12); }

          // RANK Card
          Group #RankStatCard {
            Anchor: (Width: 165);
            LayoutMode: Top;
            Background: @BgCard;

            Group { Anchor: (Height: 3); Background: #81C784; }
            Group {
              FlexWeight: 1;
              LayoutMode: Top;
              Padding: (Left: 14, Right: 14, Top: 10, Bottom: 10);

              Group {
                LayoutMode: Left;
                Anchor: (Height: 20);

                Group { Anchor: (Width: 20, Height: 20); Background: #81C784; LayoutMode: Center;
                  Label { Text: "R"; FlexWeight: 1; Style: (FontSize: 14, TextColor: #0a1119, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center); }
                }
                Group { Anchor: (Width: 6); }
                Label { Text: "RANK"; FlexWeight: 1; Style: (FontSize: 14, TextColor: #81C784, RenderBold: true, LetterSpacing: 1, VerticalAlignment: Center); }
              }

              Label #RankValue {
                Text: "Member";
                Anchor: (Height: 42);
                Style: (FontSize: 32, TextColor: #ffffff, RenderBold: true);
              }

              Label #RankDesc {
                Text: "guild role";
                Anchor: (Height: 22);
                Style: (FontSize: 14, TextColor: #8fa4b8);
              }
            }
          }

          Group { Anchor: (Width: 12); }

          // Members Card
          Group #MembersStatCard {
            Anchor: (Width: 165);
            LayoutMode: Top;
            Background: @BgCard;

            Group { Anchor: (Height: 3); Background: #FFB74D; }
            Group {
              FlexWeight: 1;
              LayoutMode: Top;
              Padding: (Left: 14, Right: 14, Top: 10, Bottom: 10);

              Group {
                LayoutMode: Left;
                Anchor: (Height: 20);

                Group { Anchor: (Width: 20, Height: 20); Background: #FFB74D; LayoutMode: Center;
                  Label { Text: "M"; FlexWeight: 1; Style: (FontSize: 14, TextColor: #0a1119, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center); }
                }
                Group { Anchor: (Width: 6); }
                Label { Text: "MEMBERS"; FlexWeight: 1; Style: (FontSize: 14, TextColor: #FFB74D, RenderBold: true, LetterSpacing: 1, VerticalAlignment: Center); }
              }

              Label #MemberCountValue {
                Text: "0/20";
                Anchor: (Height: 42);
                Style: (FontSize: 34, TextColor: #ffffff, RenderBold: true);
              }

              Label #MembersDesc {
                Text: "guild members";
                Anchor: (Height: 22);
                Style: (FontSize: 14, TextColor: #8fa4b8);
              }
            }
          }
        }

        Group { Anchor: (Height: 12); }
      }

      // ===== FACTIONS QUICK INFO (bottom info box) =====
      Group #FactionQuickInfo {
        Background: @BgCard;
        Padding: (Full: 16);
        LayoutMode: Top;
        Visible: false;

        Label {
          Text: "INFO";
          Anchor: (Height: 20);
          Style: (FontSize: 14, TextColor: @TextSecondary, RenderBold: true, LetterSpacing: 1);
        }

        Group { Anchor: (Height: 4); }

        Label #QuickInfoText {
          Text: "";
          FlexWeight: 1;
          Style: (FontSize: 16, TextColor: #cccccc, RenderBold: false, VerticalAlignment: Start);
        }
      }

      // ===== GUILD EXTENDED STATS (Claims + Power Info) =====
      Group #GuildExtendedStats {
        Anchor: (Height: 130);
        LayoutMode: Left;
        Visible: false;

        // Claims Card
        Group #ClaimsStatCard {
          FlexWeight: 1;
          LayoutMode: Top;
          Background: @BgCard;
          Padding: (Full: 14);

          Label {
            Text: "LAND CLAIMS";
            Anchor: (Height: 20);
            Style: (FontSize: 14, TextColor: @TextSecondary, RenderBold: true, LetterSpacing: 1);
          }

          Label #ClaimsValue {
            Text: "0/0";
            Anchor: (Height: 34);
            Style: (FontSize: 28, TextColor: #9CCC65, RenderBold: true);
          }

          Label #ClaimsDesc {
            Text: "chunks claimed";
            Anchor: (Height: 22);
            Style: (FontSize: 14, TextColor: #8fa4b8);
          }

          Group { Anchor: (Height: 4); }

          // Claims progress bar
          Group #ClaimsProgressBg {
            Anchor: (Height: 6);
            Background: #0a1119;
            LayoutMode: Left;

            Group #ClaimsProgressBar {
              Anchor: (Width: 0, Height: 6);
              Background: #9CCC65;
            }
            Group #ClaimsProgressEmpty {
              FlexWeight: 1;
              Anchor: (Height: 6);
            }
          }
        }

        Group { Anchor: (Width: 12); }

        // Power Info Card
        Group #PowerInfoCard {
          FlexWeight: 1;
          LayoutMode: Top;
          Background: @BgCard;
          Padding: (Full: 14);

          Label {
            Text: "POWER INFO";
            Anchor: (Height: 20);
            Style: (FontSize: 14, TextColor: @TextSecondary, RenderBold: true, LetterSpacing: 1);
          }

          Label #PowerFormula {
            Text: "0 members x 10";
            Anchor: (Height: 26);
            Style: (FontSize: 16, TextColor: #96a9be);
          }

          Label #PowerPerMember {
            Text: "+10 power per member";
            Anchor: (Height: 26);
            Style: (FontSize: 14, TextColor: #8fa4b8);
          }

          Label #MaxClaimsInfo {
            Text: "Max claims: 0";
            Anchor: (Height: 26);
            Style: (FontSize: 14, TextColor: #9CCC65);
          }
        }
      }

      Group { Anchor: (Height: 12); }

      // ===== GUILD TAG EDITOR (for officers+) =====
      Group #GuildTagSection {
        LayoutMode: Top;
        Background: @BgCard;
        Padding: (Full: 16);
        Visible: false;

        Label {
          Text: "GUILD TAG";
          Anchor: (Height: 20);
          Style: (FontSize: 14, TextColor: @TextSecondary, RenderBold: true, LetterSpacing: 1);
        }

        Group { Anchor: (Height: 6); }

        Group {
          LayoutMode: Left;
          Anchor: (Height: 34);

          Label {
            Text: "Tag:";
            Anchor: (Width: 40);
            Style: (FontSize: 16, TextColor: #96a9be, VerticalAlignment: Center);
          }

          TextField #GuildTagInput {
            Anchor: (Width: 80, Height: 30);
            PlaceholderText: "ABC";
            MaxLength: 3;
            Style: (FontSize: 16, TextColor: #ffffff, RenderBold: true);
            Background: #0a1119;
            Padding: (Horizontal: 8);
          }

          Group { Anchor: (Width: 10); }

          TextButton #SetTagBtn {
            Text: "SET TAG";
            Anchor: (Width: 85, Height: 30);
            Style: @PrimaryButtonStyle;
          }

          Group { Anchor: (Width: 6); }

          TextButton #ClearTagBtn {
            Text: "REMOVE";
            Anchor: (Width: 75, Height: 30);
            Style: @SmallDangerButtonStyle;
          }

          Group { FlexWeight: 1; }
        }
      }

      Group { Anchor: (Height: 12); }

      // ===== GUILD ACTION BUTTONS (Leave Guild, etc.) =====
      Group #GuildActionsSection {
        Anchor: (Height: 56);
        LayoutMode: Left;
        Visible: false;

        Group { FlexWeight: 1; }

        TextButton #LeaveGuildBtn {
          Text: "LEAVE GUILD";
          Anchor: (Width: 130, Height: 36);
          Style: @SmallDangerButtonStyle;
        }

        Group { FlexWeight: 1; }
      }

      // ===== CREATE GUILD SECTION (for guildless players) =====
      Group #CreateGuildSection {
        LayoutMode: Top;
        Background: @BgCard;
        Padding: (Full: 15);
        Visible: false;

        Label {
          Text: "CREATE A GUILD";
          Anchor: (Height: 26);
          Style: (FontSize: 15, TextColor: @TextSecondary, RenderBold: true, LetterSpacing: 1);
        }

        Group { Anchor: (Height: 8); }

        // Input row with labels above
        Group {
          Anchor: (Height: 63);
          LayoutMode: Left;

          // Name input with label
          Group {
            FlexWeight: 1;
            LayoutMode: Top;

            Label {
              Text: "Guild Name";
              Anchor: (Height: 22);
              Style: (FontSize: 15, TextColor: #96a9be, RenderBold: false);
            }

            Group { Anchor: (Height: 4); }

            TextField #GuildNameInput {
              Anchor: (Height: 32);
              PlaceholderText: "Enter guild name...";
              Style: (FontSize: 16, TextColor: #ffffff, RenderBold: false);
              Background: #0a1119;
              Padding: (Horizontal: 10);
            }
          }

          Group { Anchor: (Width: 10); }

          // Tag input with label
          Group {
            Anchor: (Width: 80);
            LayoutMode: Top;

            Label {
              Text: "Tag";
              Anchor: (Height: 22);
              Style: (FontSize: 15, TextColor: #96a9be, RenderBold: false);
            }

            Group { Anchor: (Height: 4); }

            TextField #CreateGuildTagInput {
              Anchor: (Height: 32);
              PlaceholderText: "TAG";
              MaxLength: 3;
              Style: (FontSize: 16, TextColor: #ffffff, RenderBold: true);
              Background: #0a1119;
              Padding: (Horizontal: 8);
            }
          }

          Group { Anchor: (Width: 10); }

          // Create button aligned to bottom
          Group {
            Anchor: (Width: 90);
            LayoutMode: Top;

            Group { FlexWeight: 1; }

            TextButton #CreateGuildBtn {
              Text: "CREATE";
              Anchor: (Height: 32);
              Style: @SuccessButtonStyle;
            }
          }
        }

        Label #CreateGuildError {
          Text: "";
          Anchor: (Height: 20);
          Style: (FontSize: 13, TextColor: #ff6b6b);
          Visible: false;
        }
      }

      // ===== GENERIC STAT SECTION (fallback for simple stat displays) =====
      Group #StatSection {
        Visible: false;
        LayoutMode: Top;

        Group #StatRow0 {
          Anchor: (Height: 32, Bottom: 3);
          Background: #1b2532(0.8);
