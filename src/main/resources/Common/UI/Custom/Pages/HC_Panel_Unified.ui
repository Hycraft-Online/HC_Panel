      // ===== GUIDE SECTION (Rich Formatting) =====
      Group #GuideSection {
        FlexWeight: 1;
        LayoutMode: Top;
        Visible: false;

        // Scrollable guide content with rich cards
        Group #GuideScroll {
          FlexWeight: 1;
          LayoutMode: TopScrolling;
          ScrollbarStyle: @PanelScrollbarStyle;
          Padding: (Top: 4, Right: 12);

          // Header image for guide section
          Group #GuideHeaderImage {
            Anchor: (Width: 700, Height: 200);
            Background: PatchStyle(TexturePath: "../GuideHeaders/GuideOverview.png");
            Visible: false;
          }

          Group #GuideHeaderSpacer { Anchor: (Height: 12); Visible: false; }

          // Introduction card (welcome text)
          Group #GuideIntroCard {
            LayoutMode: Top;
            Background: #1b2532;
            Padding: (Full: 14);
            Visible: false;

            Label #GuideIntroText {
              Text: "";
              Style: (FontSize: 15, TextColor: #c8d6e5, Wrap: true);
            }
          }

          Group #GuideIntroSpacer { Anchor: (Height: 12); Visible: false; }

          // ===== CONTENT CARD 0 =====
          Group #GuideCard0 {
            Anchor: (Height: 200);
            LayoutMode: Left;
            Visible: false;

            Group #GuideCard0Accent {
              Anchor: (Width: 4);
              Background: #4ecdc4;
            }

            Group {
              FlexWeight: 1;
              LayoutMode: Top;
              Background: #1b2532;
              Padding: (Full: 14);

              // Card header with icon
              Group {
                LayoutMode: Left;
                Anchor: (Height: 28);

                Label #GuideCard0Icon {
                  Text: "";
                  Anchor: (Width: 24, Height: 28);
                  Background: #2a3a4a;
                  Style: (FontSize: 16, TextColor: #4ecdc4, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center);
                }

                Group { Anchor: (Width: 10); }

                Label #GuideCard0Title {
                  Text: "";
                  FlexWeight: 1;
                  Style: (FontSize: 16, TextColor: #ffffff, RenderBold: true, VerticalAlignment: Center, LetterSpacing: 1);
                }
              }

              Group { Anchor: (Height: 10); }

              // Card content
              Label #GuideCard0Text {
                Text: "";
                Style: (FontSize: 14, TextColor: #96a9be, Wrap: true);
              }

              // Bullet list container
              Group #GuideCard0Bullets {
                LayoutMode: Top;
                Padding: (Top: 8);
                Visible: false;

                // Bullet 0
                Group #GuideCard0Bullet0 {
                  LayoutMode: Left;
                  Anchor: (Height: 26);
                  Visible: false;

                  Label { Text: ">"; Anchor: (Width: 20); Style: (FontSize: 14, TextColor: #4ecdc4, RenderBold: true, VerticalAlignment: Center); }
                  Label #GuideCard0Bullet0Text { Text: ""; FlexWeight: 1; Style: (FontSize: 14, TextColor: #c8d6e5, VerticalAlignment: Center); }
                }

                // Bullet 1
                Group #GuideCard0Bullet1 {
                  LayoutMode: Left;
                  Anchor: (Height: 26);
                  Visible: false;

                  Label { Text: ">"; Anchor: (Width: 20); Style: (FontSize: 14, TextColor: #4ecdc4, RenderBold: true, VerticalAlignment: Center); }
                  Label #GuideCard0Bullet1Text { Text: ""; FlexWeight: 1; Style: (FontSize: 14, TextColor: #c8d6e5, VerticalAlignment: Center); }
                }

                // Bullet 2
                Group #GuideCard0Bullet2 {
                  LayoutMode: Left;
                  Anchor: (Height: 26);
                  Visible: false;

                  Label { Text: ">"; Anchor: (Width: 20); Style: (FontSize: 14, TextColor: #4ecdc4, RenderBold: true, VerticalAlignment: Center); }
                  Label #GuideCard0Bullet2Text { Text: ""; FlexWeight: 1; Style: (FontSize: 14, TextColor: #c8d6e5, VerticalAlignment: Center); }
                }

                // Bullet 3
