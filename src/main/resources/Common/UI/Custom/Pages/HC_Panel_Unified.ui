            }
          }

          Group { Anchor: (Height: 4); }

          Group {
            LayoutMode: Left;
            Anchor: (Height: 26);

            Group {
              FlexWeight: 1;
              LayoutMode: Top;

              Label { Text: "SPELL"; Anchor: (Height: 10); Style: (FontSize: 7, TextColor: #555555, LetterSpacing: 1); }
              Label #SpellPowerValue { Text: "0"; Anchor: (Height: 16); Style: (FontSize: 14, TextColor: @ColorInt, RenderBold: true); }
            }

            Group {
              FlexWeight: 1;
              LayoutMode: Top;

              Label { Text: "CRIT"; Anchor: (Height: 10); Style: (FontSize: 7, TextColor: #555555, LetterSpacing: 1); }
              Label #CritChanceValue { Text: "0%"; Anchor: (Height: 16); Style: (FontSize: 14, TextColor: @TextGold, RenderBold: true); }
            }
          }
        }

        Group { Anchor: (Width: 8); }

        // Resources Card
        Group {
          FlexWeight: 1;
          LayoutMode: Top;
          Background: @BgCard;
          Padding: (Full: 12);

          Label {
            Text: "RESOURCES";
            Anchor: (Height: 16);
            Style: (FontSize: 9, TextColor: @TextSecondary, RenderBold: true, LetterSpacing: 1);
          }

          Group { Anchor: (Height: 6); }

          // HP row - shows Base + Vitality Bonus = Total
          Group {
            LayoutMode: Left;
            Anchor: (Height: 22);

            Label { Text: "HP"; Anchor: (Width: 22); Style: (FontSize: 10, TextColor: #e74c3c, RenderBold: true, VerticalAlignment: Center); }
            Label #MaxHPValue { Text: "0+0=0"; Anchor: (Width: 100); Style: (FontSize: 11, TextColor: #e74c3c, RenderBold: true, VerticalAlignment: Center); }
            Label #HPRegenValue { Text: "+0/s"; FlexWeight: 1; Style: (FontSize: 9, TextColor: #555555, HorizontalAlignment: End, VerticalAlignment: Center); }
          }

          Group { Anchor: (Height: 4); }

          // MP row - shows Base + Intellect Bonus = Total
          Group {
            LayoutMode: Left;
            Anchor: (Height: 22);

            Label { Text: "MP"; Anchor: (Width: 22); Style: (FontSize: 10, TextColor: #3498db, RenderBold: true, VerticalAlignment: Center); }
            Label #MaxMPValue { Text: "0+0=0"; Anchor: (Width: 100); Style: (FontSize: 11, TextColor: #3498db, RenderBold: true, VerticalAlignment: Center); }
            Label #MPRegenValue { Text: "+0/s"; FlexWeight: 1; Style: (FontSize: 9, TextColor: #555555, HorizontalAlignment: End, VerticalAlignment: Center); }
          }
        }
      }

      Group #AttrCombatResourcesSpacer { Anchor: (Height: 10); Visible: false; }

      // ===== NEW ATTRIBUTES UI: DEFENSE & RESISTANCES =====
      Group #DefenseSection {
        Anchor: (Height: 75);
