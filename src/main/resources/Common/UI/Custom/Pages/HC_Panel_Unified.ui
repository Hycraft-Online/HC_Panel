      // ===== HONOR SHOP COMING SOON NOTICE =====
      Group #HonorShopComingSoon {
        Visible: false;
        Anchor: (Height: 300);
        LayoutMode: Top;

        Group { FlexWeight: 1; }

        Group {
          Anchor: (Height: 120);
          LayoutMode: Top;

          Label {
            Text: "HONOR SHOP";
            Anchor: (Height: 28);
            Style: (FontSize: 18, TextColor: #d4af37, RenderBold: true, LetterSpacing: 2, HorizontalAlignment: Center);
          }

          Group { Anchor: (Height: 16); }

          Label {
            Text: "Coming Soon";
            Anchor: (Height: 36);
            Style: (FontSize: 28, TextColor: #8fa4b8, RenderBold: true, HorizontalAlignment: Center);
          }

          Group { Anchor: (Height: 12); }

          Label {
            Text: "Spend your honor on exclusive rewards";
            Anchor: (Height: 20);
            Style: (FontSize: 12, TextColor: #555555, HorizontalAlignment: Center);
          }
        }

        Group { FlexWeight: 1; }
      }

