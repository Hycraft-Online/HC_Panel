      // ===== GUILD EXTENDED STATS (Bank, Claims, Power Info) =====
      Group #GuildExtendedStats {
        Anchor: (Height: 95);
        LayoutMode: Left;
        Visible: false;

        // Bank Card
        Group #BankStatCard {
          Anchor: (Width: 165);
          LayoutMode: Top;
          Background: @BgCard;
          Padding: (Full: 12);

          Label {
            Text: "BANK";
            Anchor: (Height: 16);
            Style: (FontSize: 10, TextColor: @TextSecondary, RenderBold: true, LetterSpacing: 1);
          }

          Label #BankValue {
            Text: "0";
            Anchor: (Height: 32);
            Style: (FontSize: 22, TextColor: #FFD700, RenderBold: true);
          }

          Label {
            Text: "gold coins";
            Anchor: (Height: 14);
            Style: (FontSize: 9, TextColor: #555555);
          }
        }

        Group { Anchor: (Width: 10); }

        // Claims Card
        Group #ClaimsStatCard {
          Anchor: (Width: 165);
          LayoutMode: Top;
          Background: @BgCard;
          Padding: (Full: 12);

          Label {
            Text: "LAND CLAIMS";
            Anchor: (Height: 16);
            Style: (FontSize: 10, TextColor: @TextSecondary, RenderBold: true, LetterSpacing: 1);
          }

          Label #ClaimsValue {
            Text: "0/0";
            Anchor: (Height: 32);
            Style: (FontSize: 22, TextColor: #9CCC65, RenderBold: true);
          }

          Label #ClaimsDesc {
            Text: "chunks claimed";
            Anchor: (Height: 14);
            Style: (FontSize: 9, TextColor: #555555);
          }
        }

        Group { Anchor: (Width: 10); }

        // Power Info Card
        Group #PowerInfoCard {
          Anchor: (Width: 165);
          LayoutMode: Top;
          Background: @BgCard;
          Padding: (Full: 12);

          Label {
            Text: "POWER INFO";
            Anchor: (Height: 16);
            Style: (FontSize: 10, TextColor: @TextSecondary, RenderBold: true, LetterSpacing: 1);
          }

          Label #PowerFormula {
            Text: "0 members x 10";
            Anchor: (Height: 18);
            Style: (FontSize: 11, TextColor: #96a9be);
          }

          Label #PowerPerMember {
            Text: "+10 power per member";
            Anchor: (Height: 14);
            Style: (FontSize: 9, TextColor: #555555);
          }

          Label #MaxClaimsInfo {
            Text: "Max claims: 0";
            Anchor: (Height: 14);
            Style: (FontSize: 9, TextColor: #9CCC65);
          }
        }
      }

      Group { Anchor: (Height: 8); }

      // ===== GUILD TAG EDITOR (for officers+) =====
      Group #GuildTagSection {
        Anchor: (Height: 70);
        LayoutMode: Top;
        Background: @BgCard;
        Padding: (Full: 12);
        Visible: false;

        Label {
          Text: "GUILD TAG";
          Anchor: (Height: 18);
          Style: (FontSize: 10, TextColor: @TextSecondary, RenderBold: true, LetterSpacing: 1);
        }

        Group { Anchor: (Height: 6); }

        Group {
          LayoutMode: Left;
          Anchor: (Height: 32);

          Label {
            Text: "Tag:";
            Anchor: (Width: 35);
            Style: (FontSize: 12, TextColor: #96a9be, VerticalAlignment: Center);
          }

          TextField #GuildTagInput {
            Anchor: (Width: 80, Height: 28);
            PlaceholderText: "TAG";
            MaxLength: 3;
            Style: (FontSize: 14, TextColor: #ffffff, RenderBold: true);
            Background: #0a1119;
            Padding: (Horizontal: 8);
          }

          Group { Anchor: (Width: 10); }

          TextButton #SetTagBtn {
            Text: "SET TAG";
            Anchor: (Width: 80, Height: 28);
            Style: @PrimaryButtonStyle;
          }

          Group { Anchor: (Width: 6); }

          TextButton #ClearTagBtn {
            Text: "CLEAR";
            Anchor: (Width: 60, Height: 28);
            Style: @NeutralButtonStyle;
          }

          Group { FlexWeight: 1; }

          Label #CurrentTagLabel {
            Text: "Current: [TAG]";
            Anchor: (Width: 120);
            Style: (FontSize: 11, TextColor: #4FC3F7, RenderBold: true, HorizontalAlignment: End, VerticalAlignment: Center);
          }
        }
      }

      Group { Anchor: (Height: 8); }

      // ===== GUILD ACTION BUTTONS (Leave Guild, etc.) =====
      Group #GuildActionsSection {
        Anchor: (Height: 50);
        LayoutMode: Left;
        Visible: false;

        Group { FlexWeight: 1; }

        TextButton #LeaveGuildBtn {
          Text: "LEAVE GUILD";
          Anchor: (Width: 130, Height: 36);
          Style: @SmallDangerButtonStyle;
        }

        Group { FlexWeight: 1; }
      }

      // ===== CREATE GUILD SECTION (for guildless players) =====
      Group #CreateGuildSection {
        Anchor: (Height: 120);
        LayoutMode: Top;
        Background: @BgCard;
        Padding: (Full: 15);
        Visible: false;

        Label {
          Text: "CREATE A GUILD";
          Anchor: (Height: 22);
          Style: (FontSize: 11, TextColor: @TextSecondary, RenderBold: true, LetterSpacing: 1);
        }

        Group { Anchor: (Height: 8); }

        // Input row with labels above
        Group {
          LayoutMode: Left;
          Anchor: (Height: 55);

          // Name input with label
          Group {
            FlexWeight: 1;
            LayoutMode: Top;

            Label {
              Text: "Guild Name";
              Anchor: (Height: 16);
              Style: (FontSize: 11, TextColor: #96a9be, RenderBold: false);
            }

            Group { Anchor: (Height: 4); }

            TextField #GuildNameInput {
              Anchor: (Height: 32);
              PlaceholderText: "Enter guild name...";
              Style: (FontSize: 14, TextColor: #ffffff, RenderBold: false);
              Background: #0a1119;
              Padding: (Horizontal: 10);
            }
          }

          Group { Anchor: (Width: 10); }

          // Tag input with label
          Group {
            Anchor: (Width: 80);
            LayoutMode: Top;

            Label {
              Text: "Tag";
              Anchor: (Height: 16);
              Style: (FontSize: 11, TextColor: #96a9be, RenderBold: false);
            }

            Group { Anchor: (Height: 4); }

            TextField #CreateGuildTagInput {
              Anchor: (Height: 32);
              PlaceholderText: "TAG";
              MaxLength: 3;
              Style: (FontSize: 14, TextColor: #ffffff, RenderBold: true);
              Background: #0a1119;
              Padding: (Horizontal: 8);
            }
          }

          Group { Anchor: (Width: 10); }

          // Create button aligned to bottom
          Group {
            Anchor: (Width: 90);
            LayoutMode: Top;

            Group { FlexWeight: 1; }

            TextButton #CreateGuildBtn {
              Text: "CREATE";
              Anchor: (Height: 32);
              Style: @SuccessButtonStyle;
            }
          }
        }

        Label #CreateGuildError {
          Text: "";
          Anchor: (Height: 16);
          Style: (FontSize: 10, TextColor: #ff6b6b);
          Visible: false;
        }
      }

