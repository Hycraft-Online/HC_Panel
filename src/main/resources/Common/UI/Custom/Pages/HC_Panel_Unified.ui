          Padding: (Left: 14, Right: 14);
          Visible: false;

          Label #TopGuildRank2 { Text: "3"; Anchor: (Width: 30); Style: (FontSize: 20, TextColor: #cd7f32, RenderBold: true, VerticalAlignment: Center); }
          Label #TopGuildName2 { Text: ""; Anchor: (Width: 150); Style: (FontSize: 16, TextColor: #ffffff, RenderBold: true, VerticalAlignment: Center); }
          Label #TopGuildPower2 { Text: ""; Anchor: (Width: 70); Style: (FontSize: 15, TextColor: #4FC3F7, RenderBold: true, VerticalAlignment: Center); }
          Label #TopGuildMembers2 { Text: ""; FlexWeight: 1; Style: (FontSize: 15, TextColor: #FFB74D, VerticalAlignment: Center); }
        }
      }

      // ===== ALLOCATE SECTION (for stat allocation) =====
      Group #AllocateSection {
        Visible: false;
        LayoutMode: Top;

        // Header with available points
        Group #AllocateHeader {
          LayoutMode: Top;

          Group {
            LayoutMode: Left;
            Anchor: (Height: 26);

            Label {
              Text: "Available Points:";
              Anchor: (Width: 120);
              Style: (FontSize: 15, TextColor: @TextSecondary, VerticalAlignment: Center);
            }

            Label #AvailablePointsValue {
              Text: "0";
              Anchor: (Width: 40);
              Style: (FontSize: 20, TextColor: #ffd700, RenderBold: true, VerticalAlignment: Center);
            }

            Group { FlexWeight: 1; }

            Label {
              Text: "Total Allocated:";
              Anchor: (Width: 100);
              Style: (FontSize: 14, TextColor: @TextSecondary, VerticalAlignment: Center, HorizontalAlignment: End);
            }

            Label #TotalAllocatedValue {
              Text: "0";
              Anchor: (Width: 30);
              Style: (FontSize: 14, TextColor: @TextPrimary, RenderBold: true, VerticalAlignment: Center);
            }
          }

          Group { Anchor: (Height: 1); Background: @Border; }
          Group { Anchor: (Height: 12); }
        }

        // STRENGTH Card
        Group #AllocateRow0 {
          LayoutMode: Top;
          Background: @BgCard;
          Padding: (Full: 14);

          Group {
            LayoutMode: Left;
            Anchor: (Height: 20);

            Label #AllocLabel0 { Text: "STRENGTH"; Anchor: (Width: 100); Style: (FontSize: 14, TextColor: @ColorStr, RenderBold: true, VerticalAlignment: Center); }
            Label #AllocValue0 { Text: "10"; Anchor: (Width: 35); Style: (FontSize: 16, TextColor: @TextPrimary, RenderBold: true, VerticalAlignment: Center); }
            Label #AllocAllocated0 { Text: "(+0 allocated)"; Anchor: (Width: 100); Style: (FontSize: 13, TextColor: @TextSecondary, VerticalAlignment: Center); }

            Group { FlexWeight: 1; }

            TextButton #AllocBtn0Add1 { Text: "+1"; Anchor: (Width: 40, Height: 26); Style: @AllocButtonStyle; }
            Group { Anchor: (Width: 6); }
            TextButton #AllocBtn0Add5 { Text: "+5"; Anchor: (Width: 40, Height: 26); Style: @AllocButtonStyle; }
          }

          Label #AllocDesc0 {
            Text: "Increases melee attack power (+2 AP per point)";
            Anchor: (Height: 20);
            Style: (FontSize: 13, TextColor: #555555);
          }
        }

        Group { Anchor: (Height: 6); }

        // AGILITY Card
        Group #AllocateRow1 {
          LayoutMode: Top;
          Background: @BgCard;
          Padding: (Full: 14);

          Group {
            LayoutMode: Left;
            Anchor: (Height: 20);

            Label #AllocLabel1 { Text: "AGILITY"; Anchor: (Width: 100); Style: (FontSize: 14, TextColor: @ColorAgi, RenderBold: true, VerticalAlignment: Center); }
            Label #AllocValue1 { Text: "10"; Anchor: (Width: 35); Style: (FontSize: 16, TextColor: @TextPrimary, RenderBold: true, VerticalAlignment: Center); }
            Label #AllocAllocated1 { Text: "(+0 allocated)"; Anchor: (Width: 100); Style: (FontSize: 13, TextColor: @TextSecondary, VerticalAlignment: Center); }

            Group { FlexWeight: 1; }

            TextButton #AllocBtn1Add1 { Text: "+1"; Anchor: (Width: 40, Height: 26); Style: @AllocButtonStyle; }
            Group { Anchor: (Width: 6); }
            TextButton #AllocBtn1Add5 { Text: "+5"; Anchor: (Width: 40, Height: 26); Style: @AllocButtonStyle; }
          }

          Label #AllocDesc1 {
            Text: "Increases ranged attack power and critical strike chance";
            Anchor: (Height: 20);
            Style: (FontSize: 13, TextColor: #555555);
          }
        }

        Group { Anchor: (Height: 6); }

        // INTELLECT Card
        Group #AllocateRow2 {
          LayoutMode: Top;
          Background: @BgCard;
          Padding: (Full: 14);

          Group {
            LayoutMode: Left;
            Anchor: (Height: 20);

            Label #AllocLabel2 { Text: "INTELLECT"; Anchor: (Width: 100); Style: (FontSize: 14, TextColor: @ColorInt, RenderBold: true, VerticalAlignment: Center); }
            Label #AllocValue2 { Text: "10"; Anchor: (Width: 35); Style: (FontSize: 16, TextColor: @TextPrimary, RenderBold: true, VerticalAlignment: Center); }
            Label #AllocAllocated2 { Text: "(+0 allocated)"; Anchor: (Width: 100); Style: (FontSize: 13, TextColor: @TextSecondary, VerticalAlignment: Center); }

            Group { FlexWeight: 1; }

            TextButton #AllocBtn2Add1 { Text: "+1"; Anchor: (Width: 40, Height: 26); Style: @AllocButtonStyle; }
            Group { Anchor: (Width: 6); }
            TextButton #AllocBtn2Add5 { Text: "+5"; Anchor: (Width: 40, Height: 26); Style: @AllocButtonStyle; }
          }

          Label #AllocDesc2 {
            Text: "Increases spell power (+2 SP) and mana pool (+15 MP per point)";
            Anchor: (Height: 20);
            Style: (FontSize: 13, TextColor: #555555);
          }
        }

        Group { Anchor: (Height: 6); }

        // SPIRIT Card
        Group #AllocateRow3 {
          LayoutMode: Top;
          Background: @BgCard;
          Padding: (Full: 14);

          Group {
            LayoutMode: Left;
            Anchor: (Height: 20);

            Label #AllocLabel3 { Text: "SPIRIT"; Anchor: (Width: 100); Style: (FontSize: 14, TextColor: @ColorSpi, RenderBold: true, VerticalAlignment: Center); }
            Label #AllocValue3 { Text: "10"; Anchor: (Width: 35); Style: (FontSize: 16, TextColor: @TextPrimary, RenderBold: true, VerticalAlignment: Center); }
            Label #AllocAllocated3 { Text: "(+0 allocated)"; Anchor: (Width: 100); Style: (FontSize: 13, TextColor: @TextSecondary, VerticalAlignment: Center); }

            Group { FlexWeight: 1; }

            TextButton #AllocBtn3Add1 { Text: "+1"; Anchor: (Width: 40, Height: 26); Style: @AllocButtonStyle; }
            Group { Anchor: (Width: 6); }
            TextButton #AllocBtn3Add5 { Text: "+5"; Anchor: (Width: 40, Height: 26); Style: @AllocButtonStyle; }
          }

          Label #AllocDesc3 {
            Text: "Increases health and mana regeneration";
            Anchor: (Height: 20);
            Style: (FontSize: 13, TextColor: #555555);
          }
        }

        Group { Anchor: (Height: 6); }

        // VITALITY Card
        Group #AllocateRow4 {
          LayoutMode: Top;
          Background: @BgCard;
          Padding: (Full: 14);

          Group {
            LayoutMode: Left;
            Anchor: (Height: 20);

            Label #AllocLabel4 { Text: "VITALITY"; Anchor: (Width: 100); Style: (FontSize: 14, TextColor: @ColorVit, RenderBold: true, VerticalAlignment: Center); }
            Label #AllocValue4 { Text: "10"; Anchor: (Width: 35); Style: (FontSize: 16, TextColor: @TextPrimary, RenderBold: true, VerticalAlignment: Center); }
            Label #AllocAllocated4 { Text: "(+0 allocated)"; Anchor: (Width: 100); Style: (FontSize: 13, TextColor: @TextSecondary, VerticalAlignment: Center); }

            Group { FlexWeight: 1; }

            TextButton #AllocBtn4Add1 { Text: "+1"; Anchor: (Width: 40, Height: 26); Style: @AllocButtonStyle; }
            Group { Anchor: (Width: 6); }
            TextButton #AllocBtn4Add5 { Text: "+5"; Anchor: (Width: 40, Height: 26); Style: @AllocButtonStyle; }
          }

          Label #AllocDesc4 {
            Text: "Increases maximum health (+10 HP per point)";
            Anchor: (Height: 20);
            Style: (FontSize: 13, TextColor: #555555);
          }
        }

        Group { Anchor: (Height: 12); }

        // Reset button (centered)
        Group {
          LayoutMode: Left;
          Anchor: (Height: 36);

          Group { FlexWeight: 1; }

          TextButton #ResetBtn {
            Text: "RESET ALL POINTS";
            Anchor: (Width: 160, Height: 32);
            Style: @ResetButtonStyle;
          }

          Group { FlexWeight: 1; }
        }
      }

      // ===== TALENT TREE SECTION (for class talents) =====
      Group #TalentTreeSection {
        Visible: false;
        LayoutMode: Top;
        FlexWeight: 1;

        // Header with available points
        Group #TalentTreeHeader {
          LayoutMode: Top;

          Group {
            LayoutMode: Left;
            Anchor: (Height: 26);

            Label {
              Text: "Available Points:";
              Anchor: (Width: 120);
              Style: (FontSize: 15, TextColor: @TextSecondary, VerticalAlignment: Center);
            }

            Label #TalentPointsAvailable {
              Text: "0";
              Anchor: (Width: 40);
              Style: (FontSize: 20, TextColor: #4aff7f, RenderBold: true, VerticalAlignment: Center);
            }

            Group { FlexWeight: 1; }

            Label {
              Text: "Total Spent:";
              Anchor: (Width: 80);
              Style: (FontSize: 14, TextColor: @TextSecondary, VerticalAlignment: Center, HorizontalAlignment: End);
            }

            Label #TalentPointsSpent {
              Text: "0";
              Anchor: (Width: 30);
              Style: (FontSize: 14, TextColor: @TextPrimary, RenderBold: true, VerticalAlignment: Center);
            }

            Group { Anchor: (Width: 16); }

            TextButton #TalentResetBtn {
              Text: "RESET";
              Anchor: (Width: 70, Height: 26);
              Style: @ResetButtonStyle;
            }
          }

          Group { Anchor: (Height: 1); Background: @Border; }
          Group { Anchor: (Height: 12); }
        }

        // Scrollable tier container
        Group #TalentTierScroll {
          FlexWeight: 1;
          LayoutMode: TopScrolling;
          ScrollbarStyle: @PanelScrollbarStyle;

        // TIER 0 - Two talents
        Group #TalentTier0 {
          Anchor: (Height: 87);
          LayoutMode: Left;
          Visible: true;

          Group { FlexWeight: 1; }

          // Tier 0 Node 0
          Group #TalentTier0Node0Wrap {
            Anchor: (Width: 60, Height: 76);
            LayoutMode: Top;
            TextTooltipStyle: @TalentTooltipStyle;
            TooltipText: "";

            TextButton #TalentTier0Node0Btn {
              Text: "THK";
              Anchor: (Width: 60, Height: 60);
              Style: @TalentNodeLockedStyle;
            }

            Label #TalentTier0Node0Rank {
              Text: "0/3";
              Anchor: (Height: 20);
              Style: (FontSize: 13, TextColor: #555555, HorizontalAlignment: Center);
            }
          }

          Group #TalentTier0Gap01 { Anchor: (Width: 50); }

          // Tier 0 Node 1
