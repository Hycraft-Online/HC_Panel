      // ===== TOP GUILDS SECTION (for faction overview leaderboard) =====
      Group #TopGuildsSection {
        Visible: false;
        LayoutMode: Top;

        Label {
          Text: "TOP GUILDS";
          Anchor: (Height: 26);
          Style: (FontSize: 14, TextColor: @TextSecondary, RenderBold: true, LetterSpacing: 1);
        }

        Group { Anchor: (Height: 6); }

        // Column Headers
        Group {
          Anchor: (Height: 28, Bottom: 2);
          Background: #0a1119(0.6);
          LayoutMode: Left;
          Padding: (Left: 14, Right: 14);

          Label { Text: "#"; Anchor: (Width: 30); Style: (FontSize: 13, TextColor: #6b7a8a, RenderBold: true, VerticalAlignment: Center); }
          Label { Text: "GUILD"; Anchor: (Width: 150); Style: (FontSize: 13, TextColor: #6b7a8a, RenderBold: true, LetterSpacing: 1, VerticalAlignment: Center); }
          Label { Text: "POWER"; Anchor: (Width: 70); Style: (FontSize: 13, TextColor: #6b7a8a, RenderBold: true, LetterSpacing: 1, VerticalAlignment: Center); }
          Label { Text: "MEMBERS"; FlexWeight: 1; Style: (FontSize: 13, TextColor: #6b7a8a, RenderBold: true, LetterSpacing: 1, VerticalAlignment: Center); }
        }

        Group #TopGuildRow0 {
          Anchor: (Height: 38, Bottom: 3);
          Background: #1b2532(0.8);
          LayoutMode: Left;
          Padding: (Left: 14, Right: 14);
          Visible: false;

          Label #TopGuildRank0 { Text: "1"; Anchor: (Width: 30); Style: (FontSize: 20, TextColor: #ffd700, RenderBold: true, VerticalAlignment: Center); }
          Label #TopGuildName0 { Text: ""; Anchor: (Width: 150); Style: (FontSize: 16, TextColor: #ffffff, RenderBold: true, VerticalAlignment: Center); }
          Label #TopGuildPower0 { Text: ""; Anchor: (Width: 70); Style: (FontSize: 15, TextColor: #4FC3F7, RenderBold: true, VerticalAlignment: Center); }
          Label #TopGuildMembers0 { Text: ""; FlexWeight: 1; Style: (FontSize: 15, TextColor: #FFB74D, VerticalAlignment: Center); }
        }

        Group #TopGuildRow1 {
          Anchor: (Height: 38, Bottom: 3);
          Background: #1b2532(0.8);
          LayoutMode: Left;
          Padding: (Left: 14, Right: 14);
          Visible: false;

          Label #TopGuildRank1 { Text: "2"; Anchor: (Width: 30); Style: (FontSize: 20, TextColor: #c0c0c0, RenderBold: true, VerticalAlignment: Center); }
          Label #TopGuildName1 { Text: ""; Anchor: (Width: 150); Style: (FontSize: 16, TextColor: #ffffff, RenderBold: true, VerticalAlignment: Center); }
          Label #TopGuildPower1 { Text: ""; Anchor: (Width: 70); Style: (FontSize: 15, TextColor: #4FC3F7, RenderBold: true, VerticalAlignment: Center); }
          Label #TopGuildMembers1 { Text: ""; FlexWeight: 1; Style: (FontSize: 15, TextColor: #FFB74D, VerticalAlignment: Center); }
