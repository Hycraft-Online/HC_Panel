              }
            }
          }

          Group { FlexWeight: 1; }
        }

        // Connector line between tier 0 and tier 1
        Group #TalentConnector01 {
          LayoutMode: Left;
          Anchor: (Height: 10);

          Group { FlexWeight: 1; }
          Group { Anchor: (Width: 29); }
          Group { Anchor: (Width: 2, Height: 10); Background: #3a3a5a; }
          Group { Anchor: (Width: 29); }
          Group { Anchor: (Width: 50); }
          Group { Anchor: (Width: 29); }
          Group { Anchor: (Width: 2, Height: 10); Background: #3a3a5a; }
          Group { Anchor: (Width: 29); }
          Group { FlexWeight: 1; }
        }

        // TIER 1 - Two talents (branching paths)
        Group #TalentTier1 {
          Anchor: (Height: 87);
          LayoutMode: Left;
          Visible: true;

          Group { FlexWeight: 1; }

