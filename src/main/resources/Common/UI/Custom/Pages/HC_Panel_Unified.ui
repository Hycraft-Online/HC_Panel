          }
        }
      }

      Group #HonorCurrencyProgressSpacer { Anchor: (Height: 12); Visible: false; }

      // ===== NEW HONOR UI: ACCOUNT STATS & DECAY ROW (70px) =====
      Group #HonorAccountDecayRow {
        Anchor: (Height: 70);
        LayoutMode: Left;
        Visible: false;

        // Lifetime Stats Card (left)
        Group {
          FlexWeight: 1;
          LayoutMode: Top;
          Background: @BgCard;
          Padding: (Full: 10);

          Label {
            Text: "ACCOUNT STATS";
            Anchor: (Height: 14);
            Style: (FontSize: 9, TextColor: @TextSecondary, RenderBold: true, LetterSpacing: 1);
          }

          Group { Anchor: (Height: 6); }

          Group {
            LayoutMode: Left;
            Anchor: (Height: 22);

            Label { Text: "Lifetime Kills:"; Anchor: (Width: 80); Style: (FontSize: 10, TextColor: @TextSecondary, VerticalAlignment: Center); }
            Label #HonorLifetimeKills { Text: "0"; Anchor: (Width: 55); Style: (FontSize: 14, TextColor: #e74c3c, RenderBold: true, VerticalAlignment: Center); }
            Label { Text: "Highest:"; Anchor: (Width: 50); Style: (FontSize: 10, TextColor: @TextSecondary, VerticalAlignment: Center); }
            Label #HonorHighestRank { Text: "R0"; FlexWeight: 1; Style: (FontSize: 14, TextColor: @TextGold, RenderBold: true, VerticalAlignment: Center); }
          }
        }

        Group { Anchor: (Width: 10); }

        // Decay Warning Card (right, red-tinted)
        Group {
          Anchor: (Width: 145);
          LayoutMode: Top;
          Background: #2a1a1a;
          Padding: (Full: 10);

          Group {
            LayoutMode: Left;
            Anchor: (Height: 14);

            Label {
              Text: "DECAY WARNING";
              FlexWeight: 1;
              Style: (FontSize: 9, TextColor: #ff6b6b, RenderBold: true, LetterSpacing: 1, VerticalAlignment: Center);
            }

            Label {
              Text: "!";
              Anchor: (Width: 16);
              Style: (FontSize: 12, TextColor: #ff6b6b, HorizontalAlignment: End, VerticalAlignment: Center);
            }
          }

          Group { Anchor: (Height: 6); }

          Group {
            LayoutMode: Left;
            Anchor: (Height: 22);

            Label #HonorDecayAmount {
              Text: "-0 RP";
              Anchor: (Width: 80);
              Style: (FontSize: 16, TextColor: #ff6b6b, RenderBold: true, VerticalAlignment: Center);
            }

            Label {
              Text: "(20%)";
              FlexWeight: 1;
              Style: (FontSize: 10, TextColor: #8b4444, VerticalAlignment: Center);
            }
          }
        }
      }

      // ===== NEW ATTRIBUTES UI: HERO CLASS SECTION =====
      Group #AttrHeroSection {
        Anchor: (Height: 100);
        LayoutMode: Top;
        Visible: false;

        Group {
          Anchor: (Height: 85);
