              Text: "END";
              Anchor: (Width: 60, Height: 60);
              Style: @TalentNodeLockedStyle;
            }

            Label #TalentTier0Node1Rank {
              Text: "0/2";
              Anchor: (Height: 20);
              Style: (FontSize: 13, TextColor: #555555, HorizontalAlignment: Center);
            }
          }

          // Tier 0 Node 2 (hidden by default, includes its gap)
          Group #TalentTier0Node2Wrap {
            Anchor: (Width: 110, Height: 76);
            LayoutMode: Left;
            Visible: false;

            Group { Anchor: (Width: 50); }
            Group {
              Anchor: (Width: 60, Height: 76);
              LayoutMode: Top;
              TextTooltipStyle: @TalentTooltipStyle;
              TooltipText: "";

              TextButton #TalentTier0Node2Btn {
                Text: "";
                Anchor: (Width: 60, Height: 60);
                Style: @TalentNodeLockedStyle;
              }

              Label #TalentTier0Node2Rank {
                Text: "";
                Anchor: (Height: 20);
                Style: (FontSize: 13, TextColor: #555555, HorizontalAlignment: Center);
              }
            }
          }

          // Tier 0 Node 3 (hidden by default, includes its gap)
          Group #TalentTier0Node3Wrap {
            Anchor: (Width: 110, Height: 76);
            LayoutMode: Left;
            Visible: false;

            Group { Anchor: (Width: 50); }
