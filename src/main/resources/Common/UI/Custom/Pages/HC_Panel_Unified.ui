      // ===== INVITE PLAYER SECTION (for officers+ in Members view) =====
      Group #InvitePlayerSection {
        LayoutMode: Top;
        Background: @BgCard;
        Padding: (Full: 16);
        Visible: false;

        Label {
          Text: "INVITE PLAYER";
          Anchor: (Height: 22);
          Style: (FontSize: 13, TextColor: @TextSecondary, RenderBold: true, LetterSpacing: 1);
        }

        Group { Anchor: (Height: 6); }

        Group {
          LayoutMode: Left;
          Anchor: (Height: 32);

          TextField #InvitePlayerInput {
            FlexWeight: 1;
            Anchor: (Height: 32);
            PlaceholderText: "Enter player name...";
            Style: (FontSize: 15, TextColor: #ffffff, RenderBold: false);
            Background: #0a1119;
            Padding: (Horizontal: 10);
          }

          Group { Anchor: (Width: 10); }

          TextButton #InvitePlayerBtn {
            Text: "INVITE";
            Anchor: (Width: 80, Height: 32);
            Style: @SuccessButtonStyle;
          }
        }
      }

      Group { Anchor: (Height: 8); }

      // ===== MEMBER LIST SECTION (visual rows with online indicator + role badge + actions) =====
      Group #MemberListSection {
        Visible: false;
        LayoutMode: Top;

        Label #MemberListTitle {
          Text: "MEMBERS";
          Anchor: (Height: 26);
          Style: (FontSize: 14, TextColor: @TextSecondary, RenderBold: true, LetterSpacing: 1);
        }

        Group { Anchor: (Height: 6); }

        // Column Headers (fixed, outside scroll)
        Group {
          Anchor: (Height: 28, Bottom: 2);
          Background: #0a1119(0.6);
          LayoutMode: Left;
          Padding: (Left: 12, Right: 8);

          Group { Anchor: (Width: 18); }
          Label { Text: "NAME"; Anchor: (Width: 120); Style: (FontSize: 13, TextColor: #6b7a8a, RenderBold: true, LetterSpacing: 1, VerticalAlignment: Center); }
          Label { Text: "ROLE"; Anchor: (Width: 80); Style: (FontSize: 13, TextColor: #6b7a8a, RenderBold: true, LetterSpacing: 1, VerticalAlignment: Center); }
          Group { FlexWeight: 1; }
          Label { Text: "ACTIONS"; Anchor: (Width: 100); Style: (FontSize: 13, TextColor: #6b7a8a, RenderBold: true, LetterSpacing: 1, HorizontalAlignment: End, VerticalAlignment: Center); }
