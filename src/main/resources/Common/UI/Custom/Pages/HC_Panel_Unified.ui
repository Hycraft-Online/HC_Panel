      // ===== HONOR SHOP COMING SOON NOTICE =====
      Group #HonorShopComingSoon {
        Visible: false;
        LayoutMode: Top;

        Group { FlexWeight: 1; }

        Group {
          LayoutMode: Top;

          Label {
            Text: "HONOR SHOP";
            Anchor: (Height: 32);
            Style: (FontSize: 22, TextColor: #d4af37, RenderBold: true, LetterSpacing: 2, HorizontalAlignment: Center);
          }

          Group { Anchor: (Height: 20); }

          Label {
            Text: "Coming Soon";
            Anchor: (Height: 36);
            Style: (FontSize: 32, TextColor: #8fa4b8, RenderBold: true, HorizontalAlignment: Center);
          }

          Group { Anchor: (Height: 12); }

          Label {
            Text: "Spend your honor on exclusive rewards";
            Anchor: (Height: 20);
            Style: (FontSize: 14, TextColor: #555555, HorizontalAlignment: Center);
          }
        }

        Group { FlexWeight: 1; }
      }

