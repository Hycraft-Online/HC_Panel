                }
              }

              TextButton #SettingsToggle0Btn {
                Text: "TOGGLE";
                Anchor: (Width: 70, Height: 32);
                Style: @PrimaryButtonStyle;
              }
            }
          }

          Group #SettingsToggle0Spacer { Anchor: (Height: 10); Visible: false; }

          // End spacer for scroll padding
          Group { Anchor: (Height: 10); }
        }

        Group { Anchor: (Height: 12); }

        // Tip card (enhanced)
        Group #GuideTipCard {
          Anchor: (Height: 56);
          LayoutMode: Left;
          Visible: false;

          // Left accent bar
          Group {
            Anchor: (Width: 4);
            Background: #4ecdc4;
          }

          Group {
            FlexWeight: 1;
            LayoutMode: Top;
            Background: #1a2a33;
            Padding: (Full: 16);

            Group {
              LayoutMode: Left;
              Anchor: (Height: 28);

              Label #GuideTipIcon {
                Text: "!";
                Anchor: (Width: 24, Height: 28);
                Background: #2a4a4a;
                Style: (FontSize: 16, TextColor: #4ecdc4, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center);
              }

              Group { Anchor: (Width: 10); }

              Label #GuideTipText {
                Text: "";
                FlexWeight: 1;
                Style: (FontSize: 14, TextColor: #8fb8b4, VerticalAlignment: Center);
              }
            }
          }
        }
      }

      // ===== FOOTER INFO (matches original HC_Attributes footer styling) =====
      Label #FooterText {
        Text: "";
        Anchor: (Height: 20);
        Style: (FontSize: 14, TextColor: #777777, HorizontalAlignment: Center);
      }
    }
  }
}
