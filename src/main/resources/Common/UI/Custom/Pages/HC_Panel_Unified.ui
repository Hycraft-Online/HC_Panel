// HC_Panel Unified - Single page for all module content
// Rich styling matching HC_Honor, HC_Attributes, and HC_Factions panels

// Colors - matching original panels
@BgDark = #0a1119(0.95);
@BgLight = #141c26(0.98);
@BgCard = #1b2532(0.5);
@TextPrimary = #ffffff;
@TextSecondary = #96a9be;
@TextGold = #d4af37;
@TextBlue = #4a9eff;
@TextPurple = #8b5cf6;
@TextGreen = #4aff7f;
@TextRed = #e74c3c;
@Border = #2b3542;

// Attribute colors
@ColorStr = #ff6b6b;
@ColorAgi = #4ecdc4;
@ColorInt = #45b7d1;
@ColorSpi = #9b59b6;
@ColorVit = #e67e22;

// Menu Button Style
@MenuButtonStyle = TextButtonStyle(
  Default: (Background: #000000(0), LabelStyle: (FontSize: 14, TextColor: #96a9be, RenderBold: true, VerticalAlignment: Center)),
  Hovered: (Background: #1b2532, LabelStyle: (FontSize: 14, TextColor: #ffffff, RenderBold: true, VerticalAlignment: Center)),
  Pressed: (Background: #0e151e, LabelStyle: (FontSize: 14, TextColor: #96a9be, RenderBold: true, VerticalAlignment: Center)),
);

// Danger Button (Close only)
@DangerButtonStyle = TextButtonStyle(
  Default: (Background: #8b3a3a, LabelStyle: (FontSize: 14, TextColor: #ffffff, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center)),
  Hovered: (Background: #9b4a4a, LabelStyle: (FontSize: 14, TextColor: #ffffff, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center)),
  Pressed: (Background: #7b2a2a, LabelStyle: (FontSize: 14, TextColor: #ffffff, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center)),
);

// Neutral Button (Back navigation)
@NeutralButtonStyle = TextButtonStyle(
  Default: (Background: #3a3f4a, LabelStyle: (FontSize: 14, TextColor: #ffffff, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center)),
  Hovered: (Background: #4a4f5a, LabelStyle: (FontSize: 14, TextColor: #ffffff, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center)),
  Pressed: (Background: #2a2f3a, LabelStyle: (FontSize: 14, TextColor: #ffffff, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center)),
);

// Primary Action Button (Join, Accept)
@PrimaryButtonStyle = TextButtonStyle(
  Default: (Background: #3a7bd5, LabelStyle: (FontSize: 11, TextColor: #ffffff, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center)),
  Hovered: (Background: #4a8be5, LabelStyle: (FontSize: 11, TextColor: #ffffff, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center)),
  Pressed: (Background: #2a6bc5, LabelStyle: (FontSize: 11, TextColor: #ffffff, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center)),
);

// Success Button (Accept)
@SuccessButtonStyle = TextButtonStyle(
  Default: (Background: #3a8b4a, LabelStyle: (FontSize: 11, TextColor: #ffffff, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center)),
  Hovered: (Background: #4a9b5a, LabelStyle: (FontSize: 11, TextColor: #ffffff, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center)),
  Pressed: (Background: #2a7b3a, LabelStyle: (FontSize: 11, TextColor: #ffffff, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center)),
);

// Small Danger Button (Decline)
@SmallDangerButtonStyle = TextButtonStyle(
  Default: (Background: #8b3a3a, LabelStyle: (FontSize: 11, TextColor: #ffffff, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center)),
  Hovered: (Background: #9b4a4a, LabelStyle: (FontSize: 11, TextColor: #ffffff, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center)),
  Pressed: (Background: #7b2a2a, LabelStyle: (FontSize: 11, TextColor: #ffffff, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center)),
);

// Allocate Button (Dark Forest Green - matches original HC_Attributes)
@AllocButtonStyle = TextButtonStyle(
  Default: (Background: #2d5a3d, LabelStyle: (FontSize: 12, TextColor: #ffffff, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center)),
  Hovered: (Background: #3d7a4d, LabelStyle: (FontSize: 12, TextColor: #ffffff, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center)),
  Pressed: (Background: #1d4a2d, LabelStyle: (FontSize: 12, TextColor: #ffffff, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center)),
);

// Reset Button (Red)
@ResetButtonStyle = TextButtonStyle(
  Default: (Background: #8b3a3a, LabelStyle: (FontSize: 12, TextColor: #ffffff, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center)),
  Hovered: (Background: #9b4a4a, LabelStyle: (FontSize: 12, TextColor: #ffffff, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center)),
  Pressed: (Background: #7b2a2a, LabelStyle: (FontSize: 12, TextColor: #ffffff, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center)),
);

// Scrollbar Style for scrollable lists
@PanelScrollbarStyle = ScrollbarStyle(
  Spacing: 6,
  Size: 8
);

// Talent Node Button Style (transparent clickable overlay)
@TalentNodeLockedStyle = TextButtonStyle(
  Default: (Background: #2a2a3a, LabelStyle: (FontSize: 16, TextColor: #555555, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center)),
  Hovered: (Background: #3a3a4a, LabelStyle: (FontSize: 16, TextColor: #666666, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center)),
  Pressed: (Background: #2a2a3a, LabelStyle: (FontSize: 16, TextColor: #555555, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center)),
);

@TalentNodeAvailableStyle = TextButtonStyle(
  Default: (Background: #2a4a3a, LabelStyle: (FontSize: 16, TextColor: #4aff7f, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center)),
  Hovered: (Background: #3a5a4a, LabelStyle: (FontSize: 16, TextColor: #5affaf, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center)),
  Pressed: (Background: #1a3a2a, LabelStyle: (FontSize: 16, TextColor: #4aff7f, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center)),
);

@TalentNodeMaxedStyle = TextButtonStyle(
  Default: (Background: #3a3a5a, LabelStyle: (FontSize: 16, TextColor: #ffd700, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center)),
  Hovered: (Background: #4a4a6a, LabelStyle: (FontSize: 16, TextColor: #ffe740, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center)),
  Pressed: (Background: #3a3a5a, LabelStyle: (FontSize: 16, TextColor: #ffd700, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center)),
);

// Talent Tooltip Style - constrained width
@TalentTooltipStyle = TextTooltipStyle(
  Background: #1a1a2a,
  MaxWidth: 250,
  LabelStyle: (Wrap: true, FontSize: 12, TextColor: #ffffff),
  Padding: 12
);

// Page overlay background
Group {
  Background: #000000(0.5);

  Group {
    Anchor: (Width: 850, Height: 550);
    LayoutMode: Left;

    // ===== LEFT PANEL (Sidebar) =====
    Group #LeftPanel {
      Anchor: (Width: 170);
      Background: @BgDark;
      LayoutMode: Top;
      Padding: (Full: 16);

      // Header Title
      Label #HeaderTitle {
        Text: "Hycraft Online";
        Anchor: (Height: 28);
        Style: (FontSize: 14, TextColor: @TextGold, RenderBold: true, LetterSpacing: 1);
      }

      Group { Anchor: (Height: 16); }

      // Navigation Buttons (7 slots)
      TextButton #SidebarBtn0 {
        Text: "";
        Anchor: (Height: 34);
        Style: @MenuButtonStyle;
        Visible: false;
        Padding: (Full: 10);
      }

      TextButton #SidebarBtn1 {
        Text: "";
        Anchor: (Height: 34);
        Style: @MenuButtonStyle;
        Visible: false;
        Padding: (Full: 10);
      }

      TextButton #SidebarBtn2 {
        Text: "";
        Anchor: (Height: 34);
        Style: @MenuButtonStyle;
        Visible: false;
        Padding: (Full: 10);
      }

      TextButton #SidebarBtn3 {
        Text: "";
        Anchor: (Height: 34);
        Style: @MenuButtonStyle;
        Visible: false;
        Padding: (Full: 10);
      }

      TextButton #SidebarBtn4 {
        Text: "";
        Anchor: (Height: 34);
        Style: @MenuButtonStyle;
        Visible: false;
        Padding: (Full: 10);
      }

      TextButton #SidebarBtn5 {
        Text: "";
        Anchor: (Height: 34);
        Style: @MenuButtonStyle;
        Visible: false;
        Padding: (Full: 10);
      }

      TextButton #SidebarBtn6 {
        Text: "";
        Anchor: (Height: 34);
        Style: @MenuButtonStyle;
        Visible: false;
        Padding: (Full: 10);
      }

      Group { FlexWeight: 1; }

      // Back Button (neutral gray, not danger red)
      TextButton #BackButton {
        Text: "< BACK";
        Anchor: (Height: 36);
        Style: @NeutralButtonStyle;
        Visible: false;
      }

      // Close Button
      TextButton #CloseButton {
        Text: "CLOSE";
        Anchor: (Height: 36);
        Style: @DangerButtonStyle;
        Visible: true;
      }
    }

    // ===== RIGHT PANEL (Content) =====
    Group #RightPanel {
      FlexWeight: 1;
      Background: @BgLight;
      LayoutMode: Top;
      Padding: (Full: 20);

      // ===== HEADER SECTION (used by all modules) =====
      Group #HeaderSection {
        Anchor: (Height: 70);
        LayoutMode: Top;

        // Player info row
        Group {
          LayoutMode: Left;
          Anchor: (Height: 36);

          Label #FactionTag {
            Text: "";
            Anchor: (Width: 55);
            Style: (FontSize: 16, TextColor: #4169e1, RenderBold: true, VerticalAlignment: Center);
          }

          Group {
            LayoutMode: Top;

            Label #HeaderSubtitle {
              Text: "";
              Anchor: (Height: 22);
              Style: (FontSize: 16, TextColor: @TextGold, RenderBold: true);
            }

            Label #HeaderInfo {
              Text: "";
              Anchor: (Height: 14);
              Style: (FontSize: 11, TextColor: @TextSecondary, RenderBold: false);
            }
          }

          Group { FlexWeight: 1; }

          // Badge (stat points, invitations, etc)
          Group #HeaderBadge {
            Anchor: (Width: 90, Height: 24);
            Background: #ffd700(0.2);
            LayoutMode: Left;
            Padding: (Left: 8, Right: 8);
            Visible: false;

            Label #HeaderBadgeText {
              Text: "";
              FlexWeight: 1;
              Style: (FontSize: 11, TextColor: #ffd700, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center);
            }
          }
        }

        Group { Anchor: (Height: 8); }

        // RP Progress bar (copied from HC_Honor_Panel.ui)
        Group #ProgressRow {
          LayoutMode: Left;
          Anchor: (Height: 22);
          Visible: false;

          Label #ProgressLabel {
            Text: "";
            Anchor: (Width: 140);
            Style: (FontSize: 12, TextColor: @TextPrimary, RenderBold: false, VerticalAlignment: Center);
          }

          Group #RankProgressBg {
            FlexWeight: 1;
            Anchor: (Height: 14);
            Background: #0a1119;
            LayoutMode: Left;

            Group #ProgressBar {
              Anchor: (Width: 0, Height: 14);
              Background: #8b5a2b;
            }
          }

          Label #ProgressPercent {
            Text: "";
            Anchor: (Width: 45);
            Style: (FontSize: 12, TextColor: @TextGold, RenderBold: true, HorizontalAlignment: End, VerticalAlignment: Center);
          }
        }
      }

      Group #HeaderBorder { Anchor: (Height: 1); Background: @Border; }
      Group #HeaderSpacer { Anchor: (Height: 6); }

      // ===== CONTENT TEXT (for simple messages / welcome screen) =====
      Label #ContentText {
        Text: "";
        Anchor: (Height: 80);
        Style: (FontSize: 13, TextColor: @TextPrimary);
        Visible: false;
      }

      // ===== HONOR STATS GRID (This Week / Lifetime side by side) =====
      Group #HonorStatsGrid {
        Anchor: (Height: 85);
        LayoutMode: Left;
        Visible: false;

        // THIS WEEK Column
        Group #ThisWeekCard {
          FlexWeight: 1;
          LayoutMode: Top;
          Background: @BgCard;
          Padding: (Full: 10);

          Label {
            Text: "THIS WEEK";
            Anchor: (Height: 16);
            Style: (FontSize: 9, TextColor: @TextSecondary, RenderBold: true, LetterSpacing: 1);
          }

          Group {
            LayoutMode: Left;
            Anchor: (Height: 18);

            Label { Text: "Honor:"; Anchor: (Width: 48); Style: (FontSize: 11, TextColor: @TextSecondary, VerticalAlignment: Center); }
            Label #WeeklyHonorValue { Text: "0"; FlexWeight: 1; Style: (FontSize: 11, TextColor: #ffd700, RenderBold: true, VerticalAlignment: Center); }
          }

          Group {
            LayoutMode: Left;
            Anchor: (Height: 18);

            Label { Text: "Kills:"; Anchor: (Width: 48); Style: (FontSize: 11, TextColor: @TextSecondary, VerticalAlignment: Center); }
            Label #WeeklyKillsValue { Text: "0"; FlexWeight: 1; Style: (FontSize: 11, TextColor: @TextPrimary, VerticalAlignment: Center); }
          }

          Group {
            LayoutMode: Left;
            Anchor: (Height: 18);

            Label { Text: "Bracket:"; Anchor: (Width: 48); Style: (FontSize: 11, TextColor: @TextSecondary, VerticalAlignment: Center); }
            Label #CurrentBracketValue { Text: "-"; Anchor: (Width: 16); Style: (FontSize: 11, TextColor: #4aff7f, RenderBold: true, VerticalAlignment: Center); }
            Label #BracketRewardLabel { Text: ""; FlexWeight: 1; Style: (FontSize: 10, TextColor: #4a7c59, VerticalAlignment: Center); }
          }
        }

        Group { Anchor: (Width: 8); }

        // LIFETIME Column
        Group #LifetimeCard {
          FlexWeight: 1;
          LayoutMode: Top;
          Background: @BgCard;
          Padding: (Full: 10);

          Label {
            Text: "LIFETIME";
            Anchor: (Height: 16);
            Style: (FontSize: 9, TextColor: @TextSecondary, RenderBold: true, LetterSpacing: 1);
          }

          Group {
            LayoutMode: Left;
            Anchor: (Height: 18);

            Label { Text: "Kills:"; Anchor: (Width: 48); Style: (FontSize: 11, TextColor: @TextSecondary, VerticalAlignment: Center); }
            Label #TotalKillsValue { Text: "0"; FlexWeight: 1; Style: (FontSize: 11, TextColor: #e74c3c, RenderBold: true, VerticalAlignment: Center); }
          }

          Group {
            LayoutMode: Left;
            Anchor: (Height: 18);

            Label { Text: "Honor:"; Anchor: (Width: 48); Style: (FontSize: 11, TextColor: @TextSecondary, VerticalAlignment: Center); }
            Label #SpendableHonorValue { Text: "0"; FlexWeight: 1; Style: (FontSize: 11, TextColor: #ffd700, RenderBold: true, VerticalAlignment: Center); }
          }

          Label {
            Text: "(spendable currency)";
            Anchor: (Height: 14);
            Style: (FontSize: 9, TextColor: #555555);
          }
        }
      }

      Group #HonorSpacer1 { Anchor: (Height: 12); Visible: false; }

      // ===== NEXT RANK SECTION (full width) =====
      Group #NextRankSection {
        Anchor: (Height: 50);
        LayoutMode: Top;
        Background: @BgCard;
        Padding: (Full: 10);
        Visible: false;

        Group {
          LayoutMode: Left;
          Anchor: (Height: 18);

          Label { Text: "NEXT RANK"; Anchor: (Width: 80); Style: (FontSize: 9, TextColor: @TextSecondary, RenderBold: true, LetterSpacing: 1, VerticalAlignment: Center); }
          Label #NextRankLabel { Text: ""; FlexWeight: 1; Style: (FontSize: 12, TextColor: #9932cc, RenderBold: true, VerticalAlignment: Center); }
        }

        Group {
          LayoutMode: Left;
          Anchor: (Height: 18);

          Label #RPNeededLabel { Text: ""; FlexWeight: 1; Style: (FontSize: 11, TextColor: @TextSecondary, VerticalAlignment: Center); }
        }
      }

      Group #HonorSpacer2 { Anchor: (Height: 12); Visible: false; }

      // ===== HONOR INFO ROW (Reset Timer / Decay Warning) =====
      Group #HonorInfoRow {
        Anchor: (Height: 50);
        LayoutMode: Left;
        Visible: false;

        // Reset Timer Card
        Group #ResetTimerCard {
          FlexWeight: 1;
          LayoutMode: Top;
          Background: @BgCard;
          Padding: (Full: 10);

          Label {
            Text: "WEEKLY RESET";
            Anchor: (Height: 14);
            Style: (FontSize: 9, TextColor: @TextSecondary, RenderBold: true, LetterSpacing: 1);
          }

          Label #ResetTimerLabel {
            Text: "";
            Anchor: (Height: 20);
            Style: (FontSize: 14, TextColor: #ff9f43, RenderBold: true, VerticalAlignment: Center);
          }
        }

        Group { Anchor: (Width: 8); }

        // Decay Warning Card
        Group #DecayCard {
          FlexWeight: 1;
          LayoutMode: Top;
          Background: @BgCard;
          Padding: (Full: 10);

          Label {
            Text: "ESTIMATED DECAY";
            Anchor: (Height: 14);
            Style: (FontSize: 9, TextColor: @TextSecondary, RenderBold: true, LetterSpacing: 1);
          }

          Label #DecayWarningLabel {
            Text: "";
            Anchor: (Height: 20);
            Style: (FontSize: 14, TextColor: #ff6b6b, RenderBold: true, VerticalAlignment: Center);
          }
        }
      }

      Group #HonorSpacer3 { Anchor: (Height: 12); Visible: false; }

      // ===== BRACKET PROGRESS SECTION (copied from HC_Honor_Panel.ui) =====
      Group #BracketProgressSection {
        Anchor: (Height: 45);
        LayoutMode: Top;
        Background: @BgCard;
        Padding: (Full: 10);
        Visible: false;

        Group {
          LayoutMode: Left;
          Anchor: (Height: 14);

          Label { Text: "BRACKET PROGRESS"; FlexWeight: 1; Style: (FontSize: 9, TextColor: @TextSecondary, RenderBold: true, LetterSpacing: 1, VerticalAlignment: Center); }
          Label #NextBracketLabel { Text: "1,150 to Bracket 5"; Anchor: (Width: 120); Style: (FontSize: 10, TextColor: #6b8e23, HorizontalAlignment: End, VerticalAlignment: Center); }
        }

        Group { Anchor: (Height: 4); }

        Group #BracketProgressBg {
          Anchor: (Height: 10);
          Background: #0a1119;
          LayoutMode: Left;

          Group #BracketProgressBar {
            Anchor: (Width: 0, Height: 10);
            Background: #4a7c59;
          }
        }
      }

      // ===== NEW HONOR UI: HERO RANK SECTION (120px) =====
      Group #HonorHeroSection {
        Anchor: (Height: 120);
        LayoutMode: Top;
        Visible: false;

        Group {
          Anchor: (Height: 105);
          LayoutMode: Left;

          // Large Rank Emblem with tier-colored glowing border (90x90)
          Group #HonorEmblemOuter {
            Anchor: (Width: 95, Height: 95);
            Background: #808080;
            Padding: (Full: 3);
            LayoutMode: Top;

            Group #HonorEmblemInner {
              FlexWeight: 1;
              Background: #0d1117;
              LayoutMode: Top;
              Padding: (Full: 8);

              Label {
                Text: "RANK";
                Anchor: (Height: 12);
                Style: (FontSize: 8, TextColor: @TextSecondary, RenderBold: true, LetterSpacing: 1, HorizontalAlignment: Center);
              }

              Label #HonorRankNumber {
                Text: "0";
                FlexWeight: 1;
                Style: (FontSize: 48, TextColor: #808080, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center);
              }
            }
          }

          Group { Anchor: (Width: 16); }

          // Title, player info, and progress bar
          Group {
            FlexWeight: 1;
            LayoutMode: Top;
            Padding: (Top: 2);

            // Rank title (large, colored by tier, uppercase)
            Label #HonorRankTitle {
              Text: "UNRANKED";
              Anchor: (Height: 32);
              Style: (FontSize: 24, TextColor: #808080, RenderBold: true, LetterSpacing: 2);
            }

            // Player name and faction tag row
            Group {
              LayoutMode: Left;
              Anchor: (Height: 20);

              Label #HonorFactionTag {
                Text: "";
                Anchor: (Width: 55);
                Style: (FontSize: 13, TextColor: #4169e1, RenderBold: true, VerticalAlignment: Center);
              }

              Label #HonorPlayerName {
                Text: "";
                FlexWeight: 1;
                Style: (FontSize: 13, TextColor: @TextPrimary, VerticalAlignment: Center);
              }
            }

            Group { Anchor: (Height: 8); }

            // Full-width tier-colored progress bar
            Group #HonorHeroProgressBg {
              Anchor: (Height: 16);
              Background: #0a1119;
              LayoutMode: Left;

              Group #HonorHeroProgressBar {
                Anchor: (Width: 0, Height: 16);
                Background: #808080;
              }
            }

            Group { Anchor: (Height: 6); }

            // RP label showing "X / Y RP to [NextRank]"
            Label #HonorRPToNextRank {
              Text: "0 / 2,000 RP to Private";
              Anchor: (Height: 16);
              Style: (FontSize: 11, TextColor: @TextSecondary, VerticalAlignment: Center);
            }
          }
        }

        Group { Anchor: (Height: 1); Background: @Border; }
        Group { Anchor: (Height: 14); }
      }

      // ===== NEW HONOR UI: WEEKLY PERFORMANCE CARD (100px) =====
      Group #HonorWeeklyCard {
        Anchor: (Height: 100);
        LayoutMode: Top;
        Background: @BgCard;
        Padding: (Full: 12);
        Visible: false;

        // Header row with title and reset timer
        Group {
          LayoutMode: Left;
          Anchor: (Height: 16);

          Label {
            Text: "WEEKLY PERFORMANCE";
            FlexWeight: 1;
            Style: (FontSize: 9, TextColor: @TextSecondary, RenderBold: true, LetterSpacing: 1, VerticalAlignment: Center);
          }

          Label #HonorResetTimer {
            Text: "6d 12h";
            Anchor: (Width: 80);
            Style: (FontSize: 10, TextColor: #ff9f43, RenderBold: true, HorizontalAlignment: End, VerticalAlignment: Center);
          }
        }

        Group { Anchor: (Height: 8); }

        // Main stats row: Bracket | Weekly Honor | Kills | Avg
        Group {
          LayoutMode: Left;
          Anchor: (Height: 38);

          // Bracket section
          Group {
            Anchor: (Width: 90);
            LayoutMode: Top;

            Label {
              Text: "BRACKET";
              Anchor: (Height: 12);
              Style: (FontSize: 8, TextColor: #555555, LetterSpacing: 1);
            }

            Group {
              LayoutMode: Left;
              Anchor: (Height: 26);

              Label #HonorBracketValue {
                Text: "-";
                Anchor: (Width: 35);
                Style: (FontSize: 24, TextColor: #555555, RenderBold: true, VerticalAlignment: Center);
              }

              Label #HonorBracketRP {
                Text: "+0 RP";
                FlexWeight: 1;
                Style: (FontSize: 11, TextColor: #4a7c59, RenderBold: true, VerticalAlignment: Center);
              }
            }
          }

          // Divider
          Group { Anchor: (Width: 1, Height: 30); Background: #2a2f3a; }
          Group { Anchor: (Width: 12); }

          // Weekly Honor section
          Group {
            Anchor: (Width: 100);
            LayoutMode: Top;

            Label {
              Text: "HONOR";
              Anchor: (Height: 12);
              Style: (FontSize: 8, TextColor: #555555, LetterSpacing: 1);
            }

            Label #HonorWeeklyValue {
              Text: "0";
              Anchor: (Height: 26);
              Style: (FontSize: 20, TextColor: #ffd700, RenderBold: true, VerticalAlignment: Center);
            }
          }

          // Divider
          Group { Anchor: (Width: 1, Height: 30); Background: #2a2f3a; }
          Group { Anchor: (Width: 12); }

          // Kills section
          Group {
            Anchor: (Width: 70);
            LayoutMode: Top;

            Label {
              Text: "KILLS";
              Anchor: (Height: 12);
              Style: (FontSize: 8, TextColor: #555555, LetterSpacing: 1);
            }

            Label #HonorWeeklyKills {
              Text: "0";
              Anchor: (Height: 26);
              Style: (FontSize: 20, TextColor: #e74c3c, RenderBold: true, VerticalAlignment: Center);
            }
          }

          // Divider
          Group { Anchor: (Width: 1, Height: 30); Background: #2a2f3a; }
          Group { Anchor: (Width: 12); }

          // Average honor/kill section
          Group {
            FlexWeight: 1;
            LayoutMode: Top;

            Label {
              Text: "AVG/KILL";
              Anchor: (Height: 12);
              Style: (FontSize: 8, TextColor: #555555, LetterSpacing: 1);
            }

            Label #HonorAvgPerKill {
              Text: "-";
              Anchor: (Height: 26);
              Style: (FontSize: 16, TextColor: #8fa4b8, RenderBold: true, VerticalAlignment: Center);
            }
          }
        }

        Group { Anchor: (Height: 6); }

        // Bracket progress bar at bottom
        Group {
          LayoutMode: Left;
          Anchor: (Height: 14);

          Label #HonorBracketTarget {
            Text: "Next: Bracket 9";
            Anchor: (Width: 100);
            Style: (FontSize: 9, TextColor: #6b8e23, VerticalAlignment: Center);
          }

          Group #HonorBracketProgressBg {
            FlexWeight: 1;
            Anchor: (Height: 10);
            Background: #0a1119;
            LayoutMode: Left;

            Group #HonorBracketProgressBar {
              Anchor: (Width: 0, Height: 10);
              Background: #4a7c59;
            }
          }

          Label #HonorBracketReward {
            Text: "+2,000 RP";
