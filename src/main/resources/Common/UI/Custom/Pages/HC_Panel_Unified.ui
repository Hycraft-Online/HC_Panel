            }
          }

          Group #GuideCard5Spacer { Anchor: (Height: 10); Visible: false; }

          // ===== STATS ROW (for numeric info like rarity tiers) =====
          Group #GuideStatsRow {
            LayoutMode: Left;
            Anchor: (Height: 70);
            Visible: false;

            // Stat Card 0
            Group #GuideStat0 {
              FlexWeight: 1;
              LayoutMode: Top;
              Background: #1b2532;
              Padding: (Full: 10);
              Visible: false;

              Label #GuideStat0Label {
                Text: "";
                Anchor: (Height: 14);
                Style: (FontSize: 9, TextColor: #96a9be, RenderBold: true, LetterSpacing: 1);
              }

              Label #GuideStat0Value {
                Text: "";
                Anchor: (Height: 24);
                Style: (FontSize: 18, TextColor: #ffd700, RenderBold: true, VerticalAlignment: Center);
              }

              Label #GuideStat0Desc {
                Text: "";
                Anchor: (Height: 16);
                Style: (FontSize: 10, TextColor: #555555);
              }
            }

            Group { Anchor: (Width: 8); }

            // Stat Card 1
            Group #GuideStat1 {
              FlexWeight: 1;
              LayoutMode: Top;
              Background: #1b2532;
              Padding: (Full: 10);
              Visible: false;

              Label #GuideStat1Label {
                Text: "";
                Anchor: (Height: 14);
                Style: (FontSize: 9, TextColor: #96a9be, RenderBold: true, LetterSpacing: 1);
              }

              Label #GuideStat1Value {
                Text: "";
                Anchor: (Height: 24);
                Style: (FontSize: 18, TextColor: #4aff7f, RenderBold: true, VerticalAlignment: Center);
              }

              Label #GuideStat1Desc {
                Text: "";
                Anchor: (Height: 16);
                Style: (FontSize: 10, TextColor: #555555);
              }
            }

            Group { Anchor: (Width: 8); }

            // Stat Card 2
            Group #GuideStat2 {
              FlexWeight: 1;
              LayoutMode: Top;
              Background: #1b2532;
              Padding: (Full: 10);
              Visible: false;

              Label #GuideStat2Label {
                Text: "";
                Anchor: (Height: 14);
                Style: (FontSize: 9, TextColor: #96a9be, RenderBold: true, LetterSpacing: 1);
              }

              Label #GuideStat2Value {
                Text: "";
                Anchor: (Height: 24);
                Style: (FontSize: 18, TextColor: #4a9eff, RenderBold: true, VerticalAlignment: Center);
              }

              Label #GuideStat2Desc {
                Text: "";
                Anchor: (Height: 16);
                Style: (FontSize: 10, TextColor: #555555);
              }
            }

            Group { Anchor: (Width: 8); }

            // Stat Card 3
            Group #GuideStat3 {
              FlexWeight: 1;
              LayoutMode: Top;
              Background: #1b2532;
              Padding: (Full: 10);
              Visible: false;

              Label #GuideStat3Label {
                Text: "";
                Anchor: (Height: 14);
                Style: (FontSize: 9, TextColor: #96a9be, RenderBold: true, LetterSpacing: 1);
              }

              Label #GuideStat3Value {
                Text: "";
                Anchor: (Height: 24);
                Style: (FontSize: 18, TextColor: #8b5cf6, RenderBold: true, VerticalAlignment: Center);
              }

              Label #GuideStat3Desc {
                Text: "";
                Anchor: (Height: 16);
                Style: (FontSize: 10, TextColor: #555555);
              }
            }
          }

          Group #GuideStatsRowSpacer { Anchor: (Height: 10); Visible: false; }

          // ===== SETTINGS TOGGLE BUTTONS =====
          Group #SettingsToggle0 {
            LayoutMode: Left;
            Anchor: (Height: 42);
            Visible: false;

            Group #SettingsToggle0Accent {
              Anchor: (Width: 4);
              Background: #4aff7f;
            }

            Group {
              FlexWeight: 1;
              LayoutMode: Left;
              Background: #1a2a33;
              Padding: (Full: 10);

              Group {
                FlexWeight: 1;
                LayoutMode: Top;

                Label #SettingsToggle0Title {
                  Text: "";
                  Anchor: (Height: 16);
                  Style: (FontSize: 13, TextColor: #ffffff, RenderBold: true, LetterSpacing: 1);
                }

                Label #SettingsToggle0Status {
                  Text: "";
                  Anchor: (Height: 14);
                  Style: (FontSize: 11, TextColor: #96a9be);
                }
              }

              TextButton #SettingsToggle0Btn {
                Text: "TOGGLE";
                Anchor: (Width: 70, Height: 28);
                Style: @PrimaryButtonStyle;
              }
            }
          }

          Group #SettingsToggle0Spacer { Anchor: (Height: 10); Visible: false; }

          // End spacer for scroll padding
          Group { Anchor: (Height: 10); }
        }

        Group { Anchor: (Height: 12); }

        // Tip card (enhanced)
        Group #GuideTipCard {
          Anchor: (Height: 50);
          LayoutMode: Left;
          Visible: false;

          // Left accent bar
          Group {
            Anchor: (Width: 4);
            Background: #4ecdc4;
          }

          Group {
            FlexWeight: 1;
            LayoutMode: Top;
            Background: #1a2a33;
            Padding: (Full: 12);

            Group {
              LayoutMode: Left;
              Anchor: (Height: 24);

              Label #GuideTipIcon {
                Text: "!";
                Anchor: (Width: 24, Height: 24);
                Background: #2a4a4a;
                Style: (FontSize: 14, TextColor: #4ecdc4, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center);
              }

              Group { Anchor: (Width: 10); }

              Label #GuideTipText {
                Text: "";
                FlexWeight: 1;
                Style: (FontSize: 12, TextColor: #8fb8b4, VerticalAlignment: Center);
              }
            }
          }
        }
      }

      // ===== FOOTER INFO (matches original HC_Attributes footer styling) =====
      Label #FooterText {
        Text: "";
        Anchor: (Height: 16);
        Style: (FontSize: 9, TextColor: #555555, HorizontalAlignment: Center);
      }
    }
  }
}
