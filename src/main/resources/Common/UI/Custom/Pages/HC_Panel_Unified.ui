      // ===== GUILD LIST SECTION (visual rows for guild browser) =====
      Group #GuildListSection {
        Visible: false;
        LayoutMode: Top;

        Label #GuildListTitle {
          Text: "AVAILABLE GUILDS";
          Anchor: (Height: 26);
          Style: (FontSize: 14, TextColor: @TextSecondary, RenderBold: true, LetterSpacing: 1);
        }

        Group { Anchor: (Height: 6); }

        // Search bar
        Group {
          Anchor: (Height: 32, Bottom: 8);
          LayoutMode: Left;

          TextField #BrowserSearchInput {
            FlexWeight: 1;
            Anchor: (Height: 32);
            PlaceholderText: "Search guilds...";
            Style: (FontSize: 15, TextColor: #ffffff, RenderBold: false);
            Background: #0a1119;
            Padding: (Horizontal: 10);
          }

          Group { Anchor: (Width: 8); }

          TextButton #BrowserSearchBtn {
            Text: "SEARCH";
            Anchor: (Width: 70, Height: 32);
            Style: @PrimaryButtonStyle;
          }
        }

        // Column Headers Row
        Group #GuildListHeader {
          Anchor: (Height: 32, Bottom: 2);
          Background: #0a1119(0.6);
          LayoutMode: Left;
          Padding: (Left: 14, Right: 14);

          Label { Text: "NAME"; Anchor: (Width: 150); Style: (FontSize: 14, TextColor: #6b7a8a, RenderBold: true, LetterSpacing: 1, VerticalAlignment: Center); }
          Group { Anchor: (Width: 10); }
          Label { Text: "MEMBERS"; Anchor: (Width: 70); Style: (FontSize: 14, TextColor: #6b7a8a, RenderBold: true, LetterSpacing: 1, VerticalAlignment: Center); }
          Label { Text: "POWER"; Anchor: (Width: 60); Style: (FontSize: 14, TextColor: #6b7a8a, RenderBold: true, LetterSpacing: 1, VerticalAlignment: Center); }
          Group { FlexWeight: 1; }
          Label { Text: ""; Anchor: (Width: 55); Style: (FontSize: 13, TextColor: #6b7a8a, VerticalAlignment: Center); }
        }

