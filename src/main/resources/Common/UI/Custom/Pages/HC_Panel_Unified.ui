              }

              Label #AttrPlayerName {
                Text: "";
                FlexWeight: 1;
                Style: (FontSize: 13, TextColor: @TextPrimary, VerticalAlignment: Center);
              }
            }

            Group { Anchor: (Height: 8); }

            // Stat points available banner
            Group #AttrPointsBanner {
              Anchor: (Height: 24);
              Background: #2a3a2a;
              LayoutMode: Left;
              Padding: (Left: 10, Right: 10);
              Visible: false;

              Label {
                Text: "STAT POINTS AVAILABLE:";
                FlexWeight: 1;
                Style: (FontSize: 10, TextColor: #4aff7f, RenderBold: true, LetterSpacing: 1, VerticalAlignment: Center);
              }

              Label #AttrPointsValue {
                Text: "0";
                Anchor: (Width: 30);
                Style: (FontSize: 14, TextColor: #4aff7f, RenderBold: true, HorizontalAlignment: End, VerticalAlignment: Center);
              }
            }
          }
        }

        Group { Anchor: (Height: 1); Background: @Border; }
        Group { Anchor: (Height: 14); }
      }

      // ===== NEW ATTRIBUTES UI: PRIMARY STATS GRID =====
      Group #PrimaryAttributesCard {
        Anchor: (Height: 165);
        LayoutMode: Top;
        Visible: false;

        Label {
          Text: "PRIMARY ATTRIBUTES";
          Anchor: (Height: 18);
          Style: (FontSize: 10, TextColor: @TextSecondary, RenderBold: true, LetterSpacing: 1);
        }

        Group { Anchor: (Height: 8); }

        // Two-column grid for attributes
        Group {
          LayoutMode: Left;
          Anchor: (Height: 135);

          // Left column: STR, INT, VIT
          Group {
            FlexWeight: 1;
            LayoutMode: Top;

            // STR
            Group {
              Anchor: (Height: 42);
              Background: @BgCard;
              LayoutMode: Left;
              Padding: (Full: 8);

              Group {
                Anchor: (Width: 38, Height: 26);
                Background: #c0392b;
                LayoutMode: Top;
                Padding: (Full: 2);

                Label { Text: "STR"; FlexWeight: 1; Style: (FontSize: 10, TextColor: #ffffff, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center); }
              }

              Group { Anchor: (Width: 8); }

              Group {
                FlexWeight: 1;
                LayoutMode: Top;

                Label #AttrValue0 { Text: "10"; Anchor: (Height: 16); Style: (FontSize: 14, TextColor: @ColorStr, RenderBold: true, VerticalAlignment: Center); }
                Label #AttrDerived0 { Text: "+20 Melee AP"; Anchor: (Height: 12); Style: (FontSize: 9, TextColor: @TextGreen, VerticalAlignment: Center); }
              }
            }

            Group { Anchor: (Height: 4); }

            // INT
            Group {
              Anchor: (Height: 42);
              Background: @BgCard;
              LayoutMode: Left;
              Padding: (Full: 8);

              Group {
                Anchor: (Width: 38, Height: 26);
                Background: #8e44ad;
                LayoutMode: Top;
                Padding: (Full: 2);

                Label { Text: "INT"; FlexWeight: 1; Style: (FontSize: 10, TextColor: #ffffff, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center); }
              }

              Group { Anchor: (Width: 8); }

              Group {
                FlexWeight: 1;
                LayoutMode: Top;

                Label #AttrValue2 { Text: "10"; Anchor: (Height: 16); Style: (FontSize: 14, TextColor: @ColorInt, RenderBold: true, VerticalAlignment: Center); }
                Label #AttrDerived2 { Text: "+20 SP, +150 MP"; Anchor: (Height: 12); Style: (FontSize: 9, TextColor: @TextGreen, VerticalAlignment: Center); }
              }
            }

            Group { Anchor: (Height: 4); }

            // VIT
            Group {
              Anchor: (Height: 42);
              Background: @BgCard;
              LayoutMode: Left;
              Padding: (Full: 8);

              Group {
                Anchor: (Width: 38, Height: 26);
                Background: #27ae60;
                LayoutMode: Top;
                Padding: (Full: 2);

                Label { Text: "VIT"; FlexWeight: 1; Style: (FontSize: 10, TextColor: #ffffff, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center); }
              }

              Group { Anchor: (Width: 8); }

              Group {
                FlexWeight: 1;
                LayoutMode: Top;

                Label #AttrValue4 { Text: "10"; Anchor: (Height: 16); Style: (FontSize: 14, TextColor: @ColorVit, RenderBold: true, VerticalAlignment: Center); }
                Label #AttrDerived4 { Text: "+100 HP"; Anchor: (Height: 12); Style: (FontSize: 9, TextColor: @TextGreen, VerticalAlignment: Center); }
              }
            }
          }

          Group { Anchor: (Width: 8); }

          // Right column: AGI, SPI
          Group {
            FlexWeight: 1;
            LayoutMode: Top;

            // AGI
            Group {
              Anchor: (Height: 42);
              Background: @BgCard;
              LayoutMode: Left;
              Padding: (Full: 8);

              Group {
                Anchor: (Width: 38, Height: 26);
                Background: #16a085;
                LayoutMode: Top;
                Padding: (Full: 2);

                Label { Text: "AGI"; FlexWeight: 1; Style: (FontSize: 10, TextColor: #ffffff, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center); }
              }

              Group { Anchor: (Width: 8); }

              Group {
                FlexWeight: 1;
                LayoutMode: Top;

                Label #AttrValue1 { Text: "10"; Anchor: (Height: 16); Style: (FontSize: 14, TextColor: @ColorAgi, RenderBold: true, VerticalAlignment: Center); }
                Label #AttrDerived1 { Text: "+20 RAP, +0.5% Crit"; Anchor: (Height: 12); Style: (FontSize: 9, TextColor: @TextGreen, VerticalAlignment: Center); }
              }
            }

            Group { Anchor: (Height: 4); }

            // SPI
            Group {
              Anchor: (Height: 42);
              Background: @BgCard;
              LayoutMode: Left;
              Padding: (Full: 8);

              Group {
                Anchor: (Width: 38, Height: 26);
                Background: #2980b9;
                LayoutMode: Top;
                Padding: (Full: 2);

                Label { Text: "SPI"; FlexWeight: 1; Style: (FontSize: 10, TextColor: #ffffff, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center); }
              }

              Group { Anchor: (Width: 8); }

              Group {
                FlexWeight: 1;
                LayoutMode: Top;

                Label #AttrValue3 { Text: "10"; Anchor: (Height: 16); Style: (FontSize: 14, TextColor: @ColorSpi, RenderBold: true, VerticalAlignment: Center); }
                Label #AttrDerived3 { Text: "+5 HP/t, +10 MP/t"; Anchor: (Height: 12); Style: (FontSize: 9, TextColor: @TextGreen, VerticalAlignment: Center); }
              }
            }

            Group { Anchor: (Height: 4); }

            // Empty spacer to match left column
            Group { Anchor: (Height: 42); }
          }
        }
      }

      Group #AttrPrimaryCardSpacer { Anchor: (Height: 10); Visible: false; }

      // ===== NEW ATTRIBUTES UI: COMBAT & RESOURCES ROW =====
      Group #CombatResourcesRow {
        Anchor: (Height: 95);
        LayoutMode: Left;
        Visible: false;

        // Combat Stats Card
        Group {
          FlexWeight: 1;
          LayoutMode: Top;
          Background: @BgCard;
          Padding: (Full: 12);

          Label {
            Text: "COMBAT POWER";
            Anchor: (Height: 16);
            Style: (FontSize: 9, TextColor: @TextSecondary, RenderBold: true, LetterSpacing: 1);
          }

          Group { Anchor: (Height: 6); }

          // Main combat stats in 2x2 grid
          Group {
            LayoutMode: Left;
            Anchor: (Height: 26);

            Group {
              FlexWeight: 1;
              LayoutMode: Top;

              Label { Text: "MELEE"; Anchor: (Height: 10); Style: (FontSize: 7, TextColor: #555555, LetterSpacing: 1); }
