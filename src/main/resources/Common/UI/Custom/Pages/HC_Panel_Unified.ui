            Group {
              FlexWeight: 1;
              LayoutMode: Top;

              Label { Text: "ICE"; Anchor: (Height: 10); Style: (FontSize: 7, TextColor: #87ceeb, LetterSpacing: 1, HorizontalAlignment: Center); }
              Label #IceResValue { Text: "0"; Anchor: (Height: 18); Style: (FontSize: 12, TextColor: #87ceeb, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center); }
            }

            // Lightning
            Group {
              FlexWeight: 1;
              LayoutMode: Top;

              Label { Text: "LTNG"; Anchor: (Height: 10); Style: (FontSize: 7, TextColor: #ffd700, LetterSpacing: 1, HorizontalAlignment: Center); }
              Label #LightningResValue { Text: "0"; Anchor: (Height: 18); Style: (FontSize: 12, TextColor: #ffd700, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center); }
            }

            // Poison
            Group {
              FlexWeight: 1;
              LayoutMode: Top;

              Label { Text: "PSN"; Anchor: (Height: 10); Style: (FontSize: 7, TextColor: #32cd32, LetterSpacing: 1, HorizontalAlignment: Center); }
              Label #PoisonResValue { Text: "0"; Anchor: (Height: 18); Style: (FontSize: 12, TextColor: #32cd32, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center); }
            }

            // Magic
            Group {
              FlexWeight: 1;
              LayoutMode: Top;

              Label { Text: "MAG"; Anchor: (Height: 10); Style: (FontSize: 7, TextColor: #9370db, LetterSpacing: 1, HorizontalAlignment: Center); }
              Label #MagicResValue { Text: "0"; Anchor: (Height: 18); Style: (FontSize: 12, TextColor: #9370db, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center); }
            }
          }
