// HC_Panel Unified - Single page for all module content
// Rich styling matching HC_Honor, HC_Attributes, and HC_Factions panels

// Colors - matching original panels
@BgDark = #0a1119(0.95);
@BgLight = #141c26(0.98);
@BgCard = #1b2532(0.5);
@TextPrimary = #ffffff;
@TextSecondary = #96a9be;
@TextGold = #d4af37;
@TextBlue = #4a9eff;
@TextPurple = #8b5cf6;
@TextGreen = #4aff7f;
@TextRed = #e74c3c;
@Border = #2b3542;

// Attribute colors
@ColorStr = #ff6b6b;
@ColorAgi = #4ecdc4;
@ColorInt = #45b7d1;
@ColorSpi = #9b59b6;
@ColorVit = #e67e22;

// Menu Button Style
@MenuButtonStyle = TextButtonStyle(
  Default: (Background: #000000(0), LabelStyle: (FontSize: 16, TextColor: #96a9be, RenderBold: true, VerticalAlignment: Center)),
  Hovered: (Background: #1b2532, LabelStyle: (FontSize: 16, TextColor: #ffffff, RenderBold: true, VerticalAlignment: Center)),
  Pressed: (Background: #0e151e, LabelStyle: (FontSize: 16, TextColor: #96a9be, RenderBold: true, VerticalAlignment: Center)),
);

// Danger Button (Close only)
@DangerButtonStyle = TextButtonStyle(
  Default: (Background: #8b3a3a, LabelStyle: (FontSize: 16, TextColor: #ffffff, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center)),
  Hovered: (Background: #9b4a4a, LabelStyle: (FontSize: 16, TextColor: #ffffff, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center)),
  Pressed: (Background: #7b2a2a, LabelStyle: (FontSize: 16, TextColor: #ffffff, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center)),
);

// Neutral Button (Back navigation)
@NeutralButtonStyle = TextButtonStyle(
  Default: (Background: #3a3f4a, LabelStyle: (FontSize: 16, TextColor: #ffffff, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center)),
  Hovered: (Background: #4a4f5a, LabelStyle: (FontSize: 16, TextColor: #ffffff, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center)),
  Pressed: (Background: #2a2f3a, LabelStyle: (FontSize: 16, TextColor: #ffffff, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center)),
);

// Primary Action Button (Join, Accept)
@PrimaryButtonStyle = TextButtonStyle(
  Default: (Background: #3a7bd5, LabelStyle: (FontSize: 14, TextColor: #ffffff, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center)),
  Hovered: (Background: #4a8be5, LabelStyle: (FontSize: 14, TextColor: #ffffff, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center)),
  Pressed: (Background: #2a6bc5, LabelStyle: (FontSize: 14, TextColor: #ffffff, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center)),
);

// Success Button (Accept)
@SuccessButtonStyle = TextButtonStyle(
  Default: (Background: #3a8b4a, LabelStyle: (FontSize: 14, TextColor: #ffffff, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center)),
  Hovered: (Background: #4a9b5a, LabelStyle: (FontSize: 14, TextColor: #ffffff, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center)),
  Pressed: (Background: #2a7b3a, LabelStyle: (FontSize: 14, TextColor: #ffffff, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center)),
);

// Disabled Button (grayed out, non-interactive look)
@DisabledButtonStyle = TextButtonStyle(
  Default: (Background: #2a2d33, LabelStyle: (FontSize: 14, TextColor: #555555, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center)),
  Hovered: (Background: #2a2d33, LabelStyle: (FontSize: 14, TextColor: #555555, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center)),
  Pressed: (Background: #2a2d33, LabelStyle: (FontSize: 14, TextColor: #555555, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center)),
);

// Small Danger Button (Decline)
@SmallDangerButtonStyle = TextButtonStyle(
  Default: (Background: #8b3a3a, LabelStyle: (FontSize: 14, TextColor: #ffffff, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center)),
  Hovered: (Background: #9b4a4a, LabelStyle: (FontSize: 14, TextColor: #ffffff, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center)),
  Pressed: (Background: #7b2a2a, LabelStyle: (FontSize: 14, TextColor: #ffffff, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center)),
);

// Allocate Button (Dark Forest Green - matches original HC_Attributes)
@AllocButtonStyle = TextButtonStyle(
  Default: (Background: #2d5a3d, LabelStyle: (FontSize: 14, TextColor: #ffffff, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center)),
  Hovered: (Background: #3d7a4d, LabelStyle: (FontSize: 14, TextColor: #ffffff, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center)),
  Pressed: (Background: #1d4a2d, LabelStyle: (FontSize: 14, TextColor: #ffffff, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center)),
);

// Reset Button (Red)
@ResetButtonStyle = TextButtonStyle(
  Default: (Background: #8b3a3a, LabelStyle: (FontSize: 14, TextColor: #ffffff, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center)),
  Hovered: (Background: #9b4a4a, LabelStyle: (FontSize: 14, TextColor: #ffffff, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center)),
  Pressed: (Background: #7b2a2a, LabelStyle: (FontSize: 14, TextColor: #ffffff, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center)),
);

// Scrollbar Style for scrollable lists
@PanelScrollbarStyle = ScrollbarStyle(
  Spacing: 6,
  Size: 8
);

// Talent Node Button Style (transparent clickable overlay)
@TalentNodeLockedStyle = TextButtonStyle(
  Default: (Background: #2a2a3a, LabelStyle: (FontSize: 18, TextColor: #555555, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center)),
  Hovered: (Background: #3a3a4a, LabelStyle: (FontSize: 18, TextColor: #666666, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center)),
  Pressed: (Background: #2a2a3a, LabelStyle: (FontSize: 18, TextColor: #555555, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center)),
);

@TalentNodeAvailableStyle = TextButtonStyle(
  Default: (Background: #2a4a3a, LabelStyle: (FontSize: 18, TextColor: #4aff7f, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center)),
  Hovered: (Background: #3a5a4a, LabelStyle: (FontSize: 18, TextColor: #5affaf, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center)),
  Pressed: (Background: #1a3a2a, LabelStyle: (FontSize: 18, TextColor: #4aff7f, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center)),
);

@TalentNodeMaxedStyle = TextButtonStyle(
  Default: (Background: #3a3a5a, LabelStyle: (FontSize: 18, TextColor: #ffd700, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center)),
  Hovered: (Background: #4a4a6a, LabelStyle: (FontSize: 18, TextColor: #ffe740, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center)),
  Pressed: (Background: #3a3a5a, LabelStyle: (FontSize: 18, TextColor: #ffd700, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center)),
);

// Talent Tooltip Style - constrained width
@TalentTooltipStyle = TextTooltipStyle(
  Background: #1a1a2a,
  MaxWidth: 280,
  LabelStyle: (Wrap: true, FontSize: 14, TextColor: #ffffff),
  Padding: 14
);

// Page overlay background
Group {
  Background: #000000(0.5);

  Group {
    Anchor: (Width: 960, Height: 620);
    LayoutMode: Left;

    // ===== LEFT PANEL (Sidebar) =====
    Group #LeftPanel {
      Anchor: (Width: 200);
      Background: @BgDark;
      LayoutMode: Top;
      Padding: (Full: 20);

      // Header Title
      Label #HeaderTitle {
        Text: "Hycraft Online";
        Anchor: (Height: 36);
        Style: (FontSize: 22, TextColor: @TextGold, RenderBold: true, LetterSpacing: 1);
      }

      Group { Anchor: (Height: 20); }

      // Navigation Buttons (7 slots)
      TextButton #SidebarBtn0 {
        Text: "";
        Anchor: (Height: 40);
        Style: @MenuButtonStyle;
        Visible: false;
        Padding: (Full: 16);
      }

      TextButton #SidebarBtn1 {
        Text: "";
        Anchor: (Height: 40);
        Style: @MenuButtonStyle;
        Visible: false;
        Padding: (Full: 16);
      }

      TextButton #SidebarBtn2 {
        Text: "";
        Anchor: (Height: 40);
        Style: @MenuButtonStyle;
        Visible: false;
        Padding: (Full: 16);
      }

      TextButton #SidebarBtn3 {
        Text: "";
        Anchor: (Height: 40);
        Style: @MenuButtonStyle;
        Visible: false;
        Padding: (Full: 16);
      }

      TextButton #SidebarBtn4 {
        Text: "";
        Anchor: (Height: 40);
        Style: @MenuButtonStyle;
        Visible: false;
        Padding: (Full: 16);
      }

      TextButton #SidebarBtn5 {
        Text: "";
        Anchor: (Height: 40);
        Style: @MenuButtonStyle;
        Visible: false;
        Padding: (Full: 16);
      }

      TextButton #SidebarBtn6 {
        Text: "";
        Anchor: (Height: 40);
        Style: @MenuButtonStyle;
        Visible: false;
        Padding: (Full: 16);
      }

      Group { FlexWeight: 1; }

      // Back Button (neutral gray, not danger red)
      TextButton #BackButton {
        Text: "< BACK";
        Anchor: (Height: 40);
        Style: @NeutralButtonStyle;
        Visible: false;
      }

      // Close Button
      TextButton #CloseButton {
        Text: "CLOSE";
        Anchor: (Height: 40);
        Style: @DangerButtonStyle;
        Visible: true;
      }
    }

    // ===== RIGHT PANEL (Content) =====
    Group #RightPanel {
      FlexWeight: 1;
      Background: @BgLight;
      LayoutMode: Top;
      Padding: (Full: 20);

      // ===== HEADER SECTION (used by all modules) =====
      Group #HeaderSection {
        Anchor: (Height: 80);
        LayoutMode: Top;

        // Player info row
        Group {
          LayoutMode: Left;
          Anchor: (Height: 36);

          Label #FactionTag {
            Text: "";
            Anchor: (Width: 55);
            Style: (FontSize: 20, TextColor: #4169e1, RenderBold: true, VerticalAlignment: Center);
          }

          Group {
            LayoutMode: Top;

            Label #HeaderSubtitle {
              Text: "";
              Anchor: (Height: 26);
              Style: (FontSize: 20, TextColor: @TextGold, RenderBold: true);
            }

            Label #HeaderInfo {
              Text: "";
              Anchor: (Height: 18);
              Style: (FontSize: 14, TextColor: @TextSecondary, RenderBold: false);
            }
          }

          Group { FlexWeight: 1; }

          // Badge (stat points, invitations, etc)
          Group #HeaderBadge {
            Anchor: (Width: 90, Height: 28);
            Background: #ffd700(0.2);
            LayoutMode: Left;
            Padding: (Left: 8, Right: 8);
            Visible: false;

            Label #HeaderBadgeText {
              Text: "";
              FlexWeight: 1;
              Style: (FontSize: 14, TextColor: #ffd700, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center);
            }
          }
        }

        Group { Anchor: (Height: 8); }

        // RP Progress bar (copied from HC_Honor_Panel.ui)
        Group #ProgressRow {
          LayoutMode: Left;
          Anchor: (Height: 26);
          Visible: false;

          Label #ProgressLabel {
            Text: "";
            Anchor: (Width: 140);
            Style: (FontSize: 14, TextColor: @TextPrimary, RenderBold: false, VerticalAlignment: Center);
          }

          Group #RankProgressBg {
            FlexWeight: 1;
            Anchor: (Height: 18);
            Background: #0a1119;
            LayoutMode: Left;

            Group #ProgressBar {
              Anchor: (Width: 0, Height: 18);
              Background: #8b5a2b;
            }
          }

          Label #ProgressPercent {
            Text: "";
            Anchor: (Width: 45);
            Style: (FontSize: 14, TextColor: @TextGold, RenderBold: true, HorizontalAlignment: End, VerticalAlignment: Center);
          }
        }
      }

      Group #HeaderBorder { Anchor: (Height: 1); Background: @Border; }
      Group #HeaderSpacer { Anchor: (Height: 6); }

      // ===== CONTENT TEXT (for simple messages / welcome screen) =====
      Label #ContentText {
        Text: "";
        Anchor: (Height: 90);
        Style: (FontSize: 15, TextColor: @TextPrimary);
        Visible: false;
      }

      // ===== SKILLS SECTION (Professions + Tradeskills progress) =====
      Group #SkillsSection {
        LayoutMode: Top;
        Visible: false;

        // Section header
        Group {
          Anchor: (Height: 50);
          LayoutMode: Top;
          Padding: (Left: 10, Right: 10);

          Label #SkillsSectionTitle {
            Text: "SKILLS";
            Anchor: (Height: 24);
            Style: (FontSize: 18, TextColor: #4ecdc4, RenderBold: true, LetterSpacing: 1);
          }

          Label #SkillsSectionSubtitle {
            Text: "";
            Anchor: (Height: 18);
            Style: (FontSize: 13, TextColor: #96a9be);
          }
        }

        Group { Anchor: (Height: 1); Background: #2b3542; }
        Group { Anchor: (Height: 6); }

        // Skill rows (0-8, reused for both professions and tradeskills)
        Group #SkillRow0 {
          Anchor: (Height: 38);
          LayoutMode: Left;
          Padding: (Left: 10, Right: 10, Top: 4, Bottom: 4);
          Visible: false;

          Label #SkillName0 {
            Text: "";
            Anchor: (Width: 130);
            Style: (FontSize: 15, TextColor: #ffffff, RenderBold: true, VerticalAlignment: Center);
          }

          Label #SkillLevel0 {
            Text: "";
            Anchor: (Width: 55);
            Style: (FontSize: 14, TextColor: #ffffff, VerticalAlignment: Center, HorizontalAlignment: End);
          }

          Group { Anchor: (Width: 10); }

          Group {
            Anchor: (Width: 200, Height: 8);
            Background: #0a1119;
            LayoutMode: Left;

            Group #SkillBarFill0 {
              Anchor: (Width: 0, Height: 8);
              Background: #4ecdc4;
            }
          }

          Group { Anchor: (Width: 10); }

          Label #SkillXp0 {
            Text: "";
            FlexWeight: 1;
            Style: (FontSize: 12, TextColor: #96a9be, VerticalAlignment: Center);
          }

          Label #SkillBadge0 {
            Text: "";
            Anchor: (Width: 45);
            Style: (FontSize: 11, TextColor: #4aff7f, RenderBold: true, VerticalAlignment: Center, HorizontalAlignment: End);
            Visible: false;
          }
        }

        Group #SkillRow1 {
